# ──────────────────────────────────────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
TRUST_PROXY=1


# ──────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL via Prisma)
# ──────────────────────────────────────────────────────────────────────────────

# Local PostgreSQL (active)
DATABASE_URL=postgresql://postgres:Shruti@2004@localhost:5432/safety_qr

# Neon (cloud) — uncomment to switch
# DATABASE_URL=postgresql://neondb_owner:npg_oRrV6yLuCi2Z@ep-floral-king-a1kn5dss-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Shadow DB for Prisma migrations (optional)
# SHADOW_DATABASE_URL=postgresql://postgres:test123@localhost:5432/safety_qr_shadow?schema=public


# ──────────────────────────────────────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────────────────────────────────────

REDIS_URL=rediss://default:AQ_IAAImcDI4NzUyY2JmZGQwNDk0NjI3YWFlNmQ5NTE2NTIxOWM2MXAyNDA0MA@steady-octopus-4040.upstash.io:6379
