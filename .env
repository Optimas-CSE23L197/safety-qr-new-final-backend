JWT_ACCESS_SECRET=a563deffe36fad61e6239af1ebe0c63a0b8f4da7fe1b80a5dbe9e8a26a668721
JWT_ACCESS_EXPIRY=15m

JWT_REFRESH_SECRET=74a08a86ae90c0cf7e4454e9a6e0d42c97555dd7ea1e514f73d560af93c4943a
JWT_REFRESH_EXPIRY=30d


# ──────────────────────────────────────────────────────────────────────────────
# CSRF PROTECTION
# ──────────────────────────────────────────────────────────────────────────────

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=18233060c05f7b9dd5bd16e484f84314abb400e45de5a0688eedb424096281cf


# ──────────────────────────────────────────────────────────────────────────────
# MAINTENANCE MODE
# ──────────────────────────────────────────────────────────────────────────────

