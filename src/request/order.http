###############################################################################
# PHASE 1: CREATE ORDERS
###############################################################################

### 1.1 Create BLANK order (10 cards)
# @name createBlankOrder
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "school_id": "{{schoolId}}",
  "order_type": "BLANK",
  "card_count": 10,
  "delivery_address": {
    "name": "Principal Sharma",
    "phone": "9876543210",
    "address": "123 School Lane, Civil Lines",
    "city": "Delhi",
    "state": "Delhi",
    "pincode": "110001"
  },
  "notes": "Test BLANK order - 10 cards"
}

### 1.2 Create PRE_DETAILS order (5 cards with student data)
# @name createPreDetailsOrder
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "school_id": "{{schoolId}}",
  "order_type": "PRE_DETAILS",
  "card_count": 5,
  "items": [
    {
      "student_name": "Aarav Sharma",
      "class": "10",
      "section": "A",
      "roll_number": "101"
    },
    {
      "student_name": "Vihaan Gupta",
      "class": "10",
      "section": "A",
      "roll_number": "102"
    },
    {
      "student_name": "Ananya Singh",
      "class": "10",
      "section": "B",
      "roll_number": "103"
    },
    {
      "student_name": "Reyansh Kumar",
      "class": "9",
      "section": "A",
      "roll_number": "104"
    },
    {
      "student_name": "Sai Patel",
      "class": "9",
      "section": "B",
      "roll_number": "105"
    }
  ],
  "delivery_address": {
    "name": "Principal Sharma",
    "phone": "9876543210",
    "address": "123 School Lane, Civil Lines",
    "city": "Delhi",
    "state": "Delhi",
    "pincode": "110001"
  },
  "notes": "Test PRE_DETAILS order - 5 cards with student data"
}

###############################################################################
# PHASE 2: LIST & VIEW ORDERS
###############################################################################

### 2.1 List all orders
GET {{baseUrl}}/orders
Authorization: Bearer {{token}}

### 2.2 List orders with filters (status filter)
GET {{baseUrl}}/orders?status=PENDING&limit=10
Authorization: Bearer {{token}}

### 2.3 Get order details
GET {{baseUrl}}/orders/{{blankOrderId}}
Authorization: Bearer {{token}}

### 2.4 Get order status (simple)
GET {{baseUrl}}/orders/{{blankOrderId}}/status
Authorization: Bearer {{token}}

###############################################################################
# PHASE 3: CONFIRM ORDER (Super Admin Only)
###############################################################################

### 3.1 Confirm BLANK order
PATCH {{baseUrl}}/orders/{{blankOrderId}}/confirm
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Order approved by super admin"
}

### 3.2 Confirm PRE_DETAILS order
PATCH {{baseUrl}}/orders/{{preDetailsOrderId}}/confirm
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "PRE_DETAILS order approved"
}

###############################################################################
# PHASE 4: GENERATE ADVANCE INVOICE
###############################################################################

### 4.1 Generate advance invoice for BLANK order
POST {{baseUrl}}/orders/{{blankOrderId}}/invoice/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### 4.2 Get invoice details (by order + type)
GET {{baseUrl}}/orders/{{blankOrderId}}/invoice/advance
Authorization: Bearer {{token}}

###############################################################################
# PHASE 5: RECORD ADVANCE PAYMENT
###############################################################################

### 5.1 Record advance payment for BLANK order
PATCH {{baseUrl}}/orders/{{blankOrderId}}/payment/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 117410,
  "payment_mode": "UPI",
  "payment_ref": "PAY-ADV-001-{{$timestamp}}",
  "note": "Advance payment via UPI"
}

### 5.2 Record advance payment for PRE_DETAILS order
PATCH {{baseUrl}}/orders/{{preDetailsOrderId}}/payment/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 5000,
  "payment_mode": "BANK_TRANSFER",
  "payment_ref": "NEFT-123456789",
  "note": "Advance payment via NEFT"
}

###############################################################################
# PHASE 6: GENERATE TOKENS (Triggers token.worker)
###############################################################################

### 6.1 Generate tokens for BLANK order
POST {{baseUrl}}/orders/{{blankOrderId}}/tokens/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### 6.2 Generate tokens for PRE_DETAILS order
POST {{baseUrl}}/orders/{{preDetailsOrderId}}/tokens/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{}

###############################################################################
# PHASE 7: GENERATE CARD DESIGNS (Triggers design.worker)
###############################################################################

### 7.1 Generate card designs for BLANK order
POST {{baseUrl}}/orders/{{blankOrderId}}/design/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### 7.2 Generate card designs for PRE_DETAILS order
POST {{baseUrl}}/orders/{{preDetailsOrderId}}/design/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{}

###############################################################################
# PHASE 8: ASSIGN VENDOR
###############################################################################

### 8.1 Assign vendor to BLANK order
PATCH {{baseUrl}}/orders/{{blankOrderId}}/vendor
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "vendor_id": "{{vendorId}}",
  "vendor_notes": "Priority printing required",
  "note": "Assigned to primary vendor"
}

### 8.2 Assign vendor to PRE_DETAILS order
PATCH {{baseUrl}}/orders/{{preDetailsOrderId}}/vendor
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "vendor_id": "{{vendorId}}",
  "vendor_notes": "Standard printing",
  "note": "Assigned to primary vendor"
}

###############################################################################
# PHASE 9: PRINTING
###############################################################################

### 9.1 Start printing for BLANK order
PATCH {{baseUrl}}/orders/{{blankOrderId}}/printing
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "STARTED",
  "note": "Printing started at vendor"
}

### 9.2 Complete printing for BLANK order
PATCH {{baseUrl}}/orders/{{blankOrderId}}/printing
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "COMPLETED",
  "note": "All cards printed successfully"
}

### 9.3 Start printing for PRE_DETAILS order
PATCH {{baseUrl}}/orders/{{preDetailsOrderId}}/printing
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "STARTED",
  "note": "Printing started"
}

### 9.4 Complete printing for PRE_DETAILS order
PATCH {{baseUrl}}/orders/{{preDetailsOrderId}}/printing
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "COMPLETED",
  "note": "Printing completed"
}

###############################################################################
# PHASE 10: SHIPMENT
###############################################################################

### 10.1 Create shipment for BLANK order
POST {{baseUrl}}/orders/{{blankOrderId}}/shipment
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "awb_code": "DLV-{{$timestamp}}",
  "courier_name": "Delhivery",
  "tracking_url": "https://track.delhivery.com/{{$timestamp}}",
  "notes": "Handle with care"
}

### 10.2 Mark shipment as shipped
PATCH {{baseUrl}}/orders/{{blankOrderId}}/shipment/shipped
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Picked up by courier"
}

### 10.3 Create shipment for PRE_DETAILS order
POST {{baseUrl}}/orders/{{preDetailsOrderId}}/shipment
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "awb_code": "BLU-{{$timestamp}}",
  "courier_name": "Blue Dart",
  "tracking_url": "https://track.bluedart.com/{{$timestamp}}"
}

### 10.4 Mark PRE_DETAILS shipment as shipped
PATCH {{baseUrl}}/orders/{{preDetailsOrderId}}/shipment/shipped
Authorization: Bearer {{token}}
Content-Type: application/json

{}

###############################################################################
# PHASE 11: DELIVERY CONFIRMATION
###############################################################################

### 11.1 Confirm delivery for BLANK order
PATCH {{baseUrl}}/orders/{{blankOrderId}}/shipment/delivered
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Received by school office"
}

### 11.2 Confirm delivery for PRE_DETAILS order
PATCH {{baseUrl}}/orders/{{preDetailsOrderId}}/shipment/delivered
Authorization: Bearer {{token}}
Content-Type: application/json

{}

###############################################################################
# PHASE 12: BALANCE PAYMENT & COMPLETION
###############################################################################

### 12.1 Record balance payment for BLANK order
PATCH {{baseUrl}}/orders/{{blankOrderId}}/payment/balance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 5000,
  "payment_mode": "UPI",
  "payment_ref": "PAY-BAL-001-{{$timestamp}}",
  "note": "Balance payment completed"
}

### 12.2 Record balance payment for PRE_DETAILS order
PATCH {{baseUrl}}/orders/{{preDetailsOrderId}}/payment/balance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 5000,
  "payment_mode": "BANK_TRANSFER",
  "payment_ref": "NEFT-987654321",
  "note": "Balance payment via NEFT"
}

###############################################################################
# PHASE 13: ORCHESTRATOR MONITORING
###############################################################################

### 13.1 Check queue health
GET {{baseUrl}}/orders/orchestrator/health
Authorization: Bearer {{token}}

### 13.2 Get order status after completion
GET {{baseUrl}}/orders/{{blankOrderId}}/status
Authorization: Bearer {{token}}

### 13.3 Get PRE_DETAILS order status
GET {{baseUrl}}/orders/{{preDetailsOrderId}}/status
Authorization: Bearer {{token}}

###############################################################################
# OPTIONAL: CANCELLATION (Only works before advance payment or after refund)
###############################################################################

### Cancel order (only if in cancellable state)
POST {{baseUrl}}/orders/{{blankOrderId}}/cancel
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reason": "School requested cancellation",
  "notes": "Will process refund"
}

###############################################################################
# UTILITY: Get invoice by ID
###############################################################################

### Get invoice details by ID (replace with actual invoice ID from response)
GET {{baseUrl}}/orders/invoice/{{invoiceId}}
Authorization: Bearer {{token}}

