# =============================================================================
# order.http — RESQID Order Pipeline
# REST Client (VS Code extension: humao.rest-client)
#
# USAGE:
#   1. Fill in @token (JWT from POST /api/auth/login)
#   2. Fill in @schoolId (from your DB / super admin dashboard)
#   3. Run steps in order — copy IDs from responses into variables below
#
# PIPELINE:
#   Step 1  POST   /api/orders                         → PENDING
#   Step 2  PATCH  /api/orders/:id/confirm             → CONFIRMED
#   Step 3a POST   /api/orders/:id/invoice/advance     → PAYMENT_PENDING
#   Step 3b PATCH  /api/orders/:id/payment/advance     → ADVANCE_RECEIVED
#   Step 4  POST   /api/orders/:id/generate            → TOKEN_GENERATED
#   Step 5  POST   /api/orders/:id/design              → CARD_DESIGN_READY
#   Step 5r POST   /api/orders/:id/design/retry        → CARD_DESIGN_READY (retry)
#   Step 6  PATCH  /api/orders/:id/vendor              → SENT_TO_VENDOR
#   Step 7a PATCH  /api/orders/:id/printing/start      → PRINTING
#   Step 7b PATCH  /api/orders/:id/printing/complete   → PRINT_COMPLETE
#   Step 8a POST   /api/orders/:id/shipment            → READY_TO_SHIP
#   Step 8b PATCH  /api/orders/:id/shipment/shipped    → SHIPPED
#   Step 8c PATCH  /api/orders/:id/shipment/delivered  → BALANCE_PENDING
#   Step 9a POST   /api/orders/:id/invoice/balance     → BALANCE_PENDING (invoice issued)
#   Step 9b PATCH  /api/orders/:id/payment/balance     → COMPLETED
#   Step 10 PATCH  /api/orders/:id/cancel              → CANCELLED
#   Refund  PATCH  /api/orders/:id/refund              → REFUNDED
# =============================================================================

# ── Variables — fill these in ─────────────────────────────────────────────────

@baseUrl    = http://localhost:3000/api/v1
@token      = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..4GfNshwiYKNduPI8P19n5nZl0PMIa1flRTbfABz0ADU
@schoolId   = 4b37cafd-d57d-470b-89f5-03429711e0a7	
@vendorId   = 9d13c68f-ecd9-4d9c-a0aa-8fa76fd6b945		

# ── Copy from responses as you go ─────────────────────────────────────────────

@orderId    = 5664f1e5-906e-4e9d-b7b0-98dcc2d176ac		
@invoiceId  = 6109537b-f518-4a97-93b9-99bf77ddcebc


###############################################################################
# READ — List orders
###############################################################################

### List all orders (paginated)
GET {{baseUrl}}/orders?page=1&limit=20
Authorization: Bearer {{token}}

###

### List orders for a specific school
GET {{baseUrl}}/orders?school_id={{schoolId}}&page=1&limit=20
Authorization: Bearer {{token}}

###

### List by status
GET {{baseUrl}}/orders?status=PENDING&page=1&limit=20
Authorization: Bearer {{token}}

###

### List CALL channel orders only
GET {{baseUrl}}/orders?channel=CALL&page=1&limit=20
Authorization: Bearer {{token}}

###

### Get single order by ID
GET {{baseUrl}}/orders/{{orderId}}
Authorization: Bearer {{token}}


###############################################################################
# STEP 1 — CREATE ORDER (DASHBOARD — BLANK)
# Expected: 201 { order: { status: "PENDING" }, orderNumber: "ORD-YYYY-XXXX" }
###############################################################################

### Create DASHBOARD BLANK order
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "school_id": "{{schoolId}}",
  "channel": "DASHBOARD",
  "order_type": "BLANK",
  "card_count": 100,
  "delivery": {
    "delivery_name": "Principal Ravi Kumar",
    "delivery_phone": "+919876543210",
    "delivery_address": "123 School Lane, Near Bus Stand",
    "delivery_city": "Kolkata",
    "delivery_state": "West Bengal",
    "delivery_pincode": "700001"
  },
  "notes": "Urgent — new academic year",
  "admin_notes": "School confirmed over call"
}

###

### Create CALL order (delivery address optional at creation)
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "school_id": "{{schoolId}}",
  "channel": "CALL",
  "order_type": "BLANK",
  "card_count": 50,
  "delivery": {},
  "caller_name": "Priya Singh",
  "caller_phone": "+918765432109",
  "call_notes": "Principal called directly — needs cards by month end"
}

###

### Create PRE_DETAILS order (student list uploaded separately)
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "school_id": "{{schoolId}}",
  "channel": "DASHBOARD",
  "order_type": "PRE_DETAILS",
  "card_count": 200,
  "delivery": {
    "delivery_name": "Vice Principal Das",
    "delivery_phone": "+919123456789",
    "delivery_address": "45 Park Street",
    "delivery_city": "Mumbai",
    "delivery_state": "Maharashtra",
    "delivery_pincode": "400001"
  }
}

###

### Validation failure — missing delivery fields for DASHBOARD
# Expected: 400 with field-level errors
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "school_id": "{{schoolId}}",
  "channel": "DASHBOARD",
  "order_type": "BLANK",
  "card_count": 100,
  "delivery": {
    "delivery_name": "Principal Test"
  }
}

###

### Validation failure — card_count exceeds 1500
# Expected: 400
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "school_id": "{{schoolId}}",
  "channel": "DASHBOARD",
  "order_type": "BLANK",
  "card_count": 2000,
  "delivery": {
    "delivery_name": "Principal Test",
    "delivery_phone": "+919876543210",
    "delivery_address": "123 Test St",
    "delivery_city": "Delhi",
    "delivery_state": "Delhi",
    "delivery_pincode": "110001"
  }
}


###############################################################################
# STEP 2 — CONFIRM ORDER
# Expected: 200 { order: { status: "CONFIRMED", advance_amount, balance_amount } }
###############################################################################

### Confirm order (DASHBOARD — delivery already on order)
PATCH {{baseUrl}}/orders/{{orderId}}/confirm
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Verified school details — confirmed"
}

###

### Confirm CALL order + provide delivery address at confirm time
PATCH {{baseUrl}}/orders/{{orderId}}/confirm
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "delivery": {
    "delivery_address": "456 School Road",
    "delivery_city": "Pune",
    "delivery_state": "Maharashtra",
    "delivery_pincode": "411001"
  },
  "note": "Delivery address collected over call"
}

###

### Confirm with custom unit price (ENTERPRISE tier only)
# Expected: 403 if school is not ENTERPRISE
PATCH {{baseUrl}}/orders/{{orderId}}/confirm
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "custom_unit_price": 15000,
  "note": "Special enterprise pricing agreed"
}

###

### Idempotency — confirm already-confirmed order
# Expected: 400 (wrong status)
PATCH {{baseUrl}}/orders/{{orderId}}/confirm
Authorization: Bearer {{token}}
Content-Type: application/json

{}


###############################################################################
# STEP 3a — SEND ADVANCE INVOICE
# Expected: 201 { order: { status: "PAYMENT_PENDING" }, invoice: { invoice_number } }
###############################################################################

### Send advance invoice (default 7-day due date)
POST {{baseUrl}}/orders/{{orderId}}/invoice/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Advance invoice sent via WhatsApp"
}

###

### Send advance invoice with explicit due date
POST {{baseUrl}}/orders/{{orderId}}/invoice/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "due_at": "2026-04-15T00:00:00.000Z",
  "note": "Due by end of April as agreed"
}

###

### Idempotency — send advance invoice twice
# Expected: 409 Conflict
POST {{baseUrl}}/orders/{{orderId}}/invoice/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{}


###############################################################################
# STEP 3b — MARK ADVANCE PAID
# Expected: 200 { order: { status: "ADVANCE_RECEIVED" }, payment, batch }
###############################################################################

### Record advance payment (UPI)
PATCH {{baseUrl}}/orders/{{orderId}}/payment/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 117410,
  "payment_mode": "UPI",
  "payment_ref": "UPI-REF-20260321-001",
  "note": "Received via school UPI ID"
}

###

### Record advance payment (bank transfer)
PATCH {{baseUrl}}/orders/{{orderId}}/payment/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 234820,
  "payment_mode": "BANK_TRANSFER",
  "payment_ref": "UTR-HDFC-20260321-XYZ",
  "note": "NEFT received — UTR verified"
}

###

### Record advance payment (cheque)
PATCH {{baseUrl}}/orders/{{orderId}}/payment/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 117410,
  "payment_mode": "CHEQUE",
  "payment_ref": "CHQ-001234",
  "note": "Post-dated cheque deposited"
}

###

### Validation failure — missing required fields
# Expected: 400
PATCH {{baseUrl}}/orders/{{orderId}}/payment/advance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "payment_mode": "UPI"
}


###############################################################################
# STEP 4 — GENERATE TOKENS + QR CODES
# Expected: 201 { batchId, tokenCount, failedCount }
# Note: tokens[] is stripped from response (internal only)
###############################################################################

### Generate tokens (triggers QR PNG generation + S3 upload)
POST {{baseUrl}}/orders/{{orderId}}/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Token generation triggered manually"
}

###

### Wrong status guard — generate tokens before advance received
# Expected: 400
POST {{baseUrl}}/orders/{{orderId}}/generate
Authorization: Bearer {{token}}
Content-Type: application/json

{}


###############################################################################
# STEP 5 — CARD DESIGN
# Expected: 201 { order, designedCount, cardDesignFiles }
# Note: stub engine by default (CARD_DESIGN_ENGINE not set)
###############################################################################

### Generate card designs
POST {{baseUrl}}/orders/{{orderId}}/design
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Initial card design run"
}

###

### Retry card design (after CARD_DESIGN_REVISION)
POST {{baseUrl}}/orders/{{orderId}}/design/retry
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Retrying after school logo update"
}


###############################################################################
# STEP 6 — SEND TO VENDOR
# Expected: 200 { order: { status: "SENT_TO_VENDOR" }, vendor }
###############################################################################

### Send to vendor
PATCH {{baseUrl}}/orders/{{orderId}}/vendor
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "vendor_id": "{{vendorId}}",
  "vendor_notes": "Matte lamination, 0.76mm PVC, CR80 size",
  "note": "Files uploaded to vendor FTP"
}

###

### Missing vendor_id — validation failure
# Expected: 400
PATCH {{baseUrl}}/orders/{{orderId}}/vendor
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "vendor_notes": "Some notes"
}


###############################################################################
# STEP 7a — MARK PRINTING STARTED
# Expected: 200 { order: { status: "PRINTING" } }
###############################################################################

### Mark printing started
PATCH {{baseUrl}}/orders/{{orderId}}/printing/start
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Vendor confirmed printing started"
}


###############################################################################
# STEP 7b — MARK PRINT COMPLETE
# Expected: 200 { order: { status: "PRINT_COMPLETE" } }
# Side effects: Card.print_status → PRINTED, CardOrderItem.card_printed → true
###############################################################################

### Mark print complete
PATCH {{baseUrl}}/orders/{{orderId}}/printing/complete
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "All 100 cards printed and QC checked by vendor"
}


###############################################################################
# STEP 8a — CREATE SHIPMENT
# Expected: 201 { order: { status: "READY_TO_SHIP" }, shipment }
###############################################################################

### Create Shiprocket shipment
POST {{baseUrl}}/orders/{{orderId}}/shipment
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "shiprocket_order_id": "SR-ORD-123456",
  "shiprocket_shipment_id": "SR-SHIP-789012",
  "awb_code": "DLVR-AWB-001",
  "courier_name": "Delhivery",
  "tracking_url": "https://www.delhivery.com/track/package/DLVR-AWB-001",
  "label_url": "https://cdn.shiprocket.in/labels/SR-SHIP-789012.pdf",
  "note": "Shiprocket booking confirmed"
}

###

### Create shipment (manual courier — no Shiprocket)
POST {{baseUrl}}/orders/{{orderId}}/shipment
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "awb_code": "BLUEDART-XYZ789",
  "courier_name": "Blue Dart",
  "tracking_url": "https://www.bluedart.com/tracking/BLUEDART-XYZ789",
  "note": "Manual courier booking"
}


###############################################################################
# STEP 8b — MARK SHIPPED (picked up by courier)
# Expected: 200 { order: { status: "SHIPPED" } }
###############################################################################

### Mark shipped
PATCH {{baseUrl}}/orders/{{orderId}}/shipment/shipped
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "tracking_url": "https://www.delhivery.com/track/package/DLVR-AWB-001",
  "note": "Courier picked up from vendor — tracking shared with school"
}


###############################################################################
# STEP 8c — MARK DELIVERED
# Expected: 200 { order: { status: "BALANCE_PENDING" }, tokensIssued, balanceDueAt }
# Side effects: Token.status → ISSUED, balance_due_at set (7 days from now)
###############################################################################

### Mark delivered
PATCH {{baseUrl}}/orders/{{orderId}}/shipment/delivered
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Principal confirmed receipt — signed POD received"
}


###############################################################################
# STEP 9a — SEND BALANCE INVOICE
# Expected: 201 { invoice: { invoice_number, status: "ISSUED" } }
###############################################################################

### Send balance invoice
POST {{baseUrl}}/orders/{{orderId}}/invoice/balance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "note": "Balance invoice sent — due in 7 days"
}

###

### Send balance invoice with explicit due date
POST {{baseUrl}}/orders/{{orderId}}/invoice/balance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "due_at": "2026-04-30T00:00:00.000Z",
  "note": "Extended due date per principal request"
}

###

### Idempotency — send balance invoice twice
# Expected: 409 Conflict
POST {{baseUrl}}/orders/{{orderId}}/invoice/balance
Authorization: Bearer {{token}}
Content-Type: application/json

{}


###############################################################################
# STEP 9b — MARK BALANCE PAID → COMPLETED
# Expected: 200 { order: { status: "COMPLETED", payment_status: "PAID" }, payment }
###############################################################################

### Record balance payment
PATCH {{baseUrl}}/orders/{{orderId}}/payment/balance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 117410,
  "payment_mode": "BANK_TRANSFER",
  "payment_ref": "UTR-HDFC-20260401-BAL",
  "note": "Balance received — order fully closed"
}

###

### Validation failure — zero amount
# Expected: 400
PATCH {{baseUrl}}/orders/{{orderId}}/payment/balance
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_received": 0,
  "payment_mode": "UPI"
}


###############################################################################
# STEP 10 — CANCEL ORDER
# Expected: 200 { order: { status: "CANCELLED" }, tokensRevoked, requiresRefund }
###############################################################################

### Cancel PENDING order (no refund required)
PATCH {{baseUrl}}/orders/{{orderId}}/cancel
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reason": "School requested cancellation — budget constraints"
}

###

### Cancel after advance received (refund required)
# Expected: requiresRefund: true, tokensRevoked: N
PATCH {{baseUrl}}/orders/{{orderId}}/cancel
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reason": "School closed for renovations — order not needed"
}

###

### Validation failure — reason too short
# Expected: 400
PATCH {{baseUrl}}/orders/{{orderId}}/cancel
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reason": "ok"
}

###

### Guard — cancel past PRINT_COMPLETE
# Expected: 400 (not cancellable at this stage)
PATCH {{baseUrl}}/orders/{{orderId}}/cancel
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reason": "Trying to cancel a shipped order — should fail"
}


###############################################################################
# REFUND — Record refund issued
# Precondition: order must be CANCELLED with requiresRefund: true
# Expected: 200 { order: { status: "REFUNDED" }, payment }
###############################################################################

### Record refund
PATCH {{baseUrl}}/orders/{{orderId}}/refund
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_refunded": 117410,
  "payment_mode": "BANK_TRANSFER",
  "refund_ref": "UTR-REFUND-20260321-001",
  "note": "Refund transferred to school account"
}

###

### Refund via UPI
PATCH {{baseUrl}}/orders/{{orderId}}/refund
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_refunded": 117410,
  "payment_mode": "UPI",
  "refund_ref": "UPI-REFUND-20260321",
  "note": "Refund sent to school UPI"
}

###

### Validation failure — refund on non-CANCELLED order
# Expected: 400
PATCH {{baseUrl}}/orders/{{orderId}}/refund
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "amount_refunded": 117410,
  "payment_mode": "UPI"
}
