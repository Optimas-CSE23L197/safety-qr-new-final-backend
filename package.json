{
  "name": "new_final_backend",
  "version": "1.0.0",
  "description": "RESQID — QR-based emergency profile system by coreZ Technologies Pvt. Ltd.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon --exec \"node --import tsx/esm\" src/server.js | pino-pretty",
    "start": "node --import tsx/esm src/server.js",
    "worker:easy": "cross-env WORKER_ROLE=all node --import tsx/esm src/orchestrator/workers/index.js",
    "worker:emergency": "cross-env WORKER_ROLE=emergency node --import tsx/esm src/orchestrator/workers/index.js",
    "worker:notification": "cross-env WORKER_ROLE=notification node --import tsx/esm src/orchestrator/workers/index.js",
    "worker:background": "cross-env WORKER_ROLE=background node --import tsx/esm src/orchestrator/workers/index.js",
    "worker:pipeline": "node --import tsx/esm src/orchestrator/workers/pipeline.worker.js",
    "worker:designer": "node --import tsx/esm src/orchestrator/workers/design.worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --ext .js,.ts --fix",
    "lint:imports": "eslint src --ext .js,.ts --rule 'import/no-unresolved: error'",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:integration": "vitest --project integration",
    "test:contract": "vitest --project contract",
    "test:load": "k6 run tests/load/scan.load.js",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:contract"
  },
  "imports": {
    "#config/*": "./src/config/*",
    "#middleware/*": "./src/middleware/*",
    "#modules/*": "./src/modules/*",
    "#services/*": "./src/services/*",
    "#utils/*": "./src/utils/*",
    "#integrations/*": "./src/integrations/*",
    "#jobs/*": "./src/jobs/*",
    "#prisma/*": "./prisma/*",
    "#infrastructure/*": "./src/infrastructure/*",
    "#shared/*": "./src/shared/*",
    "#monitoring/*": "./src/monitoring/*",
    "#orchestrator/*": "./src/orchestrator/*",
    "#workers/*": "./src/orchestrator/workers/*",
    "#notifications/*": "./src/orchestrator/notifications/channel/*",
    "#routes": "./src/routes/*",
    "#templates/*": "./src/templates/*"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [],
  "author": "coreZ Technologies Pvt. Ltd.",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@aws-sdk/client-ses": "^3.1034.0",
    "@aws-sdk/s3-request-presigner": "^3.1018.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.5.0",
    "@react-email/components": "^1.0.12",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "expo-server-sdk": "^6.1.0",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.11.2",
    "express-slow-down": "^3.0.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "k6": "^0.0.0",
    "magicast": "^0.3.5",
    "morgan": "^1.10.1",
    "ms": "^2.1.3",
    "msg91-sdk": "^1.0.5",
    "multer": "^2.0.2",
    "nanoid": "^5.1.5",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^6.19.3",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "rate-limiter-flexible": "^11.0.0",
    "razorpay": "^2.9.6",
    "react-email": "^6.0.0",
    "redis": "^5.11.0",
    "resend": "^6.9.4",
    "rotating-file-stream": "^3.2.9",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "string-strip-html": "^13.5.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "uuid": "^10.0.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^22.15.30",
    "@vitest/coverage-v8": "^4.1.1",
    "axios-cookiejar-support": "^6.0.5",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jscodeshift": "^17.3.0",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "recast": "^0.23.11",
    "supertest": "^7.2.2",
    "tough-cookie": "^6.0.1",
    "vitest": "^4.1.1"
  }
}
