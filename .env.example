# =============================================================================
# RESQID — Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
TRUST_PROXY=1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/resqid
# SHADOW_DATABASE_URL=postgresql://postgres:password@localhost:5432/resqid_shadow

# ── Redis (Core) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_KEY_PREFIX=resqid:

# ── Redis Sentinel (High Availability) ───────────────────────────────────────
# Uncomment for HA setup
# REDIS_SENTINEL=true
# REDIS_SENTINEL_NAME=mymaster
# REDIS_SENTINEL_NODES='[{"host":"sentinel1","port":26379},{"host":"sentinel2","port":26379}]'

# ── Redis Cluster (Sharding) ─────────────────────────────────────────────────
# Uncomment for cluster setup
# REDIS_CLUSTER=true
# REDIS_CLUSTER_NODES='[{"host":"redis1","port":6379},{"host":"redis2","port":6379}]'

# ── Redis Connection Pool ────────────────────────────────────────────────────
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_KEEP_ALIVE=30000

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-32-byte-access-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your-32-byte-refresh-secret-here
JWT_REFRESH_EXPIRY=30d

# ── CSRF ─────────────────────────────────────────────────────────────────────
CSRF_SECRET=your-32-byte-csrf-secret-here

# ── Maintenance ──────────────────────────────────────────────────────────────
MAINTENANCE_BYPASS_SECRET=your-16-byte-maintenance-secret

# ── Application URLs ─────────────────────────────────────────────────────────
SUPER_ADMIN_URL=http://localhost:3001
SCHOOL_ADMIN_URL=http://localhost:3002
MOBILE_APP_SCHEME=capacitor://localhost
CDN_URL=http://localhost:3000/static
COOKIE_DOMAIN=localhost

# ── Public Scan URL (QR Codes) ───────────────────────────────────────────────
SCAN_BASE_URL=http://localhost:3000/s

# ── Cloudflare R2 ───────────────────────────────────────────────────────────────────
# # S2 Setup
AWS_REGION=auto
AWS_ACCESS_KEY_ID=use_your_key
AWS_SECRET_ACCESS_KEY=add_your_secret_key
AWS_S3_BUCKET=resqid-assets
AWS_ENDPOINT=use_your_end_point
#AWS_TOKEN_VALUE=cfat_DqFLldiQtbLijyPVGPPbE49VRxS06YLWjzl9ZSWWc6bdf727

# ── MSG91 (SMS) ──────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_OTP_TEMPLATE_ID=your-otp-template-id
MSG91_SENDER_ID=RESQID
MSG91_ROUTE=4

# ── Razorpay ─────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@resqid.in
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@resqid.in
EMAIL_FROM_NAME=RESQID

# ── Firebase FCM ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=resqid-prod
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@resqid-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Encryption & Hashing ─────────────────────────────────────────────────────
ENCRYPTION_KEY=64-hex-characters-32-bytes-here
LOOKUP_HASH_SECRET=32-byte-hmac-secret-here
TOKEN_HASH_SECRET=32-byte-token-hash-secret-here
SCAN_CODE_SECRET=64-byte-scan-code-secret-here

# ── Branding ─────────────────────────────────────────────────────────────────
RESQID_DEFAULT_LOGO_URL=https://resqid.in/logo.png

# ── IP Geolocation ───────────────────────────────────────────────────────────
IP_GEO_API_KEY=your-ip-geo-api-key
IP_GEO_PROVIDER=ipapi

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs

# ── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Geo Blocking ─────────────────────────────────────────────────────────────
BEHIND_CLOUDFLARE=false
BEHIND_CLOUDFRONT=false

# ── Token / QR ───────────────────────────────────────────────────────────────
TOKEN_VALIDITY_MONTHS=12
QR_DEFAULT_SIZE_PX=512

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
OTP_IP_LIMIT=20
OTP_PHONE_LIMIT=5

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@resqid.com
EMAIL_FROM_NAME=ResQID

# SMS (MSG91)
SMS_PROVIDER=msg91
SMS_API_KEY=your-msg91-api-key
SMS_SENDER_ID=RESQID
SMS_COUNTRY_CODE=91

# Push (Firebase)
FCM_PROJECT_ID=resqid-xxxxx
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FCM_CLIENT_EMAIL=firebase-adminsdk@resqid-xxxxx.iam.gserviceaccount.com