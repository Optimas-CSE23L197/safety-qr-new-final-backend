# =============================================================================
# RESQID — Environment Variables Template (FINAL)
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
TRUST_PROXY=1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/resqid

# ── Redis (Upstash / Self-hosted) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_KEY_PREFIX=resqid:

# ── Redis Connection Pool ────────────────────────────────────────────────────
REDIS_MAX_RETRIES_PER_REQUEST=1
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000
REDIS_KEEP_ALIVE=30000

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-32-byte-access-secret-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=your-32-byte-refresh-secret-here
JWT_REFRESH_EXPIRY=30d

# ── CSRF ─────────────────────────────────────────────────────────────────────
CSRF_SECRET=your-32-byte-csrf-secret-here

# ── Maintenance Mode ─────────────────────────────────────────────────────────
MAINTENANCE_BYPASS_SECRET=your-16-byte-maintenance-secret

# ── Application URLs ─────────────────────────────────────────────────────────
SUPER_ADMIN_URL=http://localhost:3001
SCHOOL_ADMIN_URL=http://localhost:3002
MOBILE_APP_SCHEME=capacitor://localhost
CDN_URL=http://localhost:3000/static
COOKIE_DOMAIN=localhost

# ── Public Scan URL (QR Codes point to this) ─────────────────────────────────
SCAN_BASE_URL=http://localhost:3000/s

# ── Cloudflare R2 / S3 Compatible Storage ────────────────────────────────────
AWS_REGION=auto
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=resqid-assets
AWS_S3_ENDPOINT=your-endpoint-url
AWS_CDN_DOMAIN=your-cdn-domain.com

# ── MSG91 (SMS Provider) ────────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_OTP_TEMPLATE_ID=your-otp-template-id
MSG91_SENDER_ID=RESQID
MSG91_ROUTE=4

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@mail.getresqid.in

# ── Expo Push Notifications (Parent App) ─────────────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token

# ── Encryption & Hashing ─────────────────────────────────────────────────────
ENCRYPTION_KEY=64-hex-characters-32-bytes-here
LOOKUP_HASH_SECRET=32-byte-hmac-secret-here
TOKEN_HASH_SECRET=32-byte-token-hash-secret-here
SCAN_CODE_SECRET=64-byte-scan-code-secret-here

# ── IP Geolocation (Optional) ────────────────────────────────────────────────
IP_GEO_API_KEY=your-ip-geo-api-key
IP_GEO_PROVIDER=ipapi

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs

# ── Sentry (Error Monitoring) ────────────────────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Rate Limiting ────────────────────────────────────────────────────────────
ENABLE_RATE_LIMIT=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
OTP_IP_LIMIT=20
OTP_PHONE_LIMIT=5

# ── Token / QR Settings ──────────────────────────────────────────────────────
TOKEN_VALIDITY_MONTHS=12
QR_DEFAULT_SIZE_PX=512

# =============================================================================
# WORKER CONFIGURATION (Orchestrator)
# =============================================================================

WORKER_ROLE=all
ENABLE_PIPELINE_QUEUE=false
SLACK_ALERTS_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz
ENABLE_STEP_METRICS=false

# ── Cloudflare (Optional — if behind Cloudflare proxy) ───────────────────────
BEHIND_CLOUDFLARE=false
BEHIND_CLOUDFRONT=false