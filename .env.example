# ==============================================================================
# RESQID — coreZ Technologies Pvt. Ltd.
# Environment Variables Reference
# ------------------------------------------------------------------------------
# Copy this file to .env and fill in all values before starting the server.
# Never commit .env to version control — only commit this .env.example file.
#
# Required vs Optional:
#   [REQUIRED] — server will NOT start without this
#   [OPTIONAL] — has a safe default or only needed in specific environments
#   [PROD ONLY] — only needed in production, ignored in development
# ==============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Application environment
# Accepted values: development | staging | production
NODE_ENV=development

# [REQUIRED] Port the HTTP server listens on
PORT=3000

# [OPTIONAL] API base URL — used in helmet CSP connectSrc
# e.g. https://api.resqid.in
API_URL=http://localhost:3000


# ──────────────────────────────────────────────────────────────────────────────
# DATABASE (PostgreSQL via Prisma)
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/resqid?schema=public

# [OPTIONAL] Shadow database for Prisma migrations (separate DB)
# Required if running migrations in a shared/cloud DB environment
# SHADOW_DATABASE_URL=postgresql://postgres:password@localhost:5432/resqid_shadow?schema=public


# ──────────────────────────────────────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Redis connection URL
# Used for: session cache, blacklist, rate limiting, OTP counters, device cache
# Format: redis://[:password@]host[:port][/db-number]
REDIS_URL=redis://localhost:6379

# [OPTIONAL] Redis password (if your Redis instance requires auth)
# REDIS_PASSWORD=

# [OPTIONAL] Redis TLS — set to "true" in production with TLS-enabled Redis
REDIS_TLS=false


# ──────────────────────────────────────────────────────────────────────────────
# JWT — ACCESS & REFRESH TOKENS
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Secret key for signing access tokens (short-lived)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 64 characters — use a cryptographically random string
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string

# [REQUIRED] Expiry duration for access tokens
# Format: vercel/ms string — e.g. 15m | 1h | 2h
JWT_ACCESS_EXPIRY=15m

# [REQUIRED] Secret key for signing refresh tokens (long-lived)
# Must be DIFFERENT from JWT_ACCESS_SECRET
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string

# [REQUIRED] Expiry duration for refresh tokens
# Format: vercel/ms string — e.g. 7d | 30d | 90d
JWT_REFRESH_EXPIRY=30d


# ──────────────────────────────────────────────────────────────────────────────
# CSRF PROTECTION
# csrf.middleware.js — double-submit cookie pattern
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Secret used to HMAC-sign CSRF tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters
CSRF_SECRET=replace_with_32_char_random_hex_string


# ──────────────────────────────────────────────────────────────────────────────
# MAINTENANCE MODE
# maintenanceMode.middleware.js — ops bypass header
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Secret value for X-Maintenance-Bypass header
# Ops use this to access the system during maintenance windows
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
MAINTENANCE_BYPASS_SECRET=replace_with_random_bypass_secret


# ──────────────────────────────────────────────────────────────────────────────
# APPLICATION URLs
# cors.middleware.js, helmet.middleware.js
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Super admin dashboard URL (CORS allowlist)
# e.g. https://admin.resqid.in
SUPER_ADMIN_URL=http://localhost:3000

# [REQUIRED] School admin dashboard URL (CORS allowlist)
# e.g. https://app.resqid.in
SCHOOL_ADMIN_URL=http://localhost:5173

# [OPTIONAL] Mobile app custom URL scheme (CORS allowlist for Capacitor)
# e.g. capacitor://resqid or com.resqid.app://
MOBILE_APP_SCHEME=capacitor://localhost

# [OPTIONAL] CDN base URL for QR assets, card images, logos
# e.g. https://cdn.resqid.in
CDN_URL=http://localhost:5000/static


# ──────────────────────────────────────────────────────────────────────────────
# AWS S3 — QR Asset + Card File Storage
# QrAsset model: storage_key (S3 path), public_url (CDN URL)
# Card model: file_url
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED in production] AWS credentials for S3
AWS_ACCESS_KEY_ID=replace_with_aws_access_key
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_key
AWS_REGION=ap-south-1

# [REQUIRED in production] S3 bucket name for QR and card files
AWS_S3_BUCKET=resqid-assets

# [OPTIONAL] S3 endpoint override (for local MinIO / S3-compatible storage)
# AWS_S3_ENDPOINT=http://localhost:9000


# ──────────────────────────────────────────────────────────────────────────────
# MSG91 — OTP & SMS
# OtpLog model: msg91_req_id (delivery tracking)
# ParentNotificationPref: scan_notify_sms, anomaly_notify_sms
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] MSG91 auth key from dashboard.msg91.com
MSG91_AUTH_KEY=replace_with_msg91_auth_key

# [REQUIRED] MSG91 OTP template ID (pre-approved DLT template)
MSG91_OTP_TEMPLATE_ID=replace_with_otp_template_id

# [REQUIRED] MSG91 sender ID (6-character DLT-registered sender)
MSG91_SENDER_ID=RESQID

# [OPTIONAL] MSG91 route (1=promotional, 4=transactional — use 4 for OTP)
MSG91_ROUTE=4


# ──────────────────────────────────────────────────────────────────────────────
# RAZORPAY — Payments & Subscriptions
# Payment model: provider_ref, is_card_fee, is_renewal
# Subscription model: provider, provider_sub_id
# WebhookEvent model: provider = "razorpay"
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Razorpay key ID from dashboard.razorpay.com
RAZORPAY_KEY_ID=replace_with_rzp_key_id

# [REQUIRED] Razorpay key secret
RAZORPAY_KEY_SECRET=replace_with_rzp_key_secret

# [REQUIRED] Razorpay webhook secret (for verifying webhook signatures)
# Set this in Razorpay dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=replace_with_rzp_webhook_secret


# ──────────────────────────────────────────────────────────────────────────────
# EMAIL — Transactional Email
# DeviceLoginLog: email_sent (device login alerts — always sent)
# ParentNotificationPref: anomaly_notify_email, card_expiry_notify
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] SMTP host for transactional email
# e.g. smtp.resend.com | smtp.sendgrid.net | email-smtp.ap-south-1.amazonaws.com
SMTP_HOST=smtp.resend.com

# [REQUIRED] SMTP port
# 587 for STARTTLS (recommended) | 465 for SSL | 25 for plain (avoid)
SMTP_PORT=587

# [REQUIRED] SMTP authentication user
SMTP_USER=replace_with_smtp_user

# [REQUIRED] SMTP authentication password / API key
SMTP_PASS=replace_with_smtp_password

# [REQUIRED] From address for all outgoing emails
EMAIL_FROM=noreply@resqid.in

# [REQUIRED] From display name
EMAIL_FROM_NAME=RESQID


# ──────────────────────────────────────────────────────────────────────────────
# PUSH NOTIFICATIONS — FCM (Firebase Cloud Messaging)
# ParentDevice model: device_token, platform (IOS | ANDROID | WEB)
# ParentNotificationPref: scan_notify_push, anomaly_notify_push
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Firebase project ID
FIREBASE_PROJECT_ID=replace_with_firebase_project_id

# [REQUIRED] Firebase service account client email
FIREBASE_CLIENT_EMAIL=replace_with_firebase_client_email

# [REQUIRED] Firebase service account private key (PEM format)
# In .env wrap the key in double quotes and use \n for newlines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_key\n-----END PRIVATE KEY-----\n"


# ──────────────────────────────────────────────────────────────────────────────
# ENCRYPTION — AES-256 for PII fields
# Student: dob_encrypted
# EmergencyContact: phone_encrypted
# EmergencyProfile: doctor_phone_encrypted
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] AES-256 encryption key for sensitive PII fields
# Must be exactly 32 bytes (64 hex characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_encryption_key

# [REQUIRED] AES-256 IV (initialization vector) — 16 bytes (32 hex characters)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_IV=replace_with_32_char_hex_iv


# ──────────────────────────────────────────────────────────────────────────────
# PHONE INDEX HASHING
# ParentUser: phone_index (hashed phone for lookup without exposing E.164)
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] HMAC secret for hashing phone numbers into phone_index
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LOOKUP_HASH_SECRET=replace_with_32_char_random_hex_string


# ──────────────────────────────────────────────────────────────────────────────
# IP GEOLOCATION — For ScanLog ip_city / ip_country fields
# ScanLog: ip_city, ip_country, ip_region
# DeviceLoginLog: ip_city, ip_country
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] IP geolocation API key (e.g. ipapi.co, ip-api.com, MaxMind)
# Used to populate ip_city/ip_country on scan logs and device login logs
# Leave empty to skip geolocation (city/country fields will be null)
IP_GEO_API_KEY=replace_with_ip_geo_api_key

# [OPTIONAL] IP geolocation provider
# Accepted values: ipapi | maxmind | ipqualityscore
IP_GEO_PROVIDER=ipapi


# ──────────────────────────────────────────────────────────────────────────────
# LOGGING — Pino
# httpLogger.middleware.js uses logger from config/logger.js
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Log level
# Accepted values: fatal | error | warn | info | debug | trace
# Recommended: info (production) | debug (development)
LOG_LEVEL=info

# [OPTIONAL] Log format
# Accepted values: json (production) | pretty (development)
LOG_FORMAT=pretty

# [OPTIONAL] Log output file path (leave empty to log to stdout only)
# LOG_FILE_PATH=/var/log/resqid/app.log


# ──────────────────────────────────────────────────────────────────────────────
# ERROR MONITORING — Sentry (optional but recommended for production)
# ──────────────────────────────────────────────────────────────────────────────

# [PROD ONLY] Sentry DSN for error tracking
# Get from sentry.io → Project → Settings → Client Keys
# SENTRY_DSN=https://replace@sentry.io/replace

# [OPTIONAL] Sentry environment tag
# SENTRY_ENVIRONMENT=production

# [OPTIONAL] Sentry sample rate (0.0 to 1.0)
# SENTRY_TRACES_SAMPLE_RATE=0.1


# ──────────────────────────────────────────────────────────────────────────────
# GEO BLOCKING — geoBlock.middleware.js
# Only needed if NOT behind Cloudflare/CloudFront (which set country headers)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Set to "true" if behind Cloudflare (enables CF-IPCountry header use)
# When true, geoBlock uses CF-IPCountry instead of IP prefix matching
BEHIND_CLOUDFLARE=false

# [OPTIONAL] Set to "true" if behind AWS CloudFront
BEHIND_CLOUDFRONT=false


# ──────────────────────────────────────────────────────────────────────────────
# RATE LIMITING — rateLimit.middleware.js + slowDown.middleware.js
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Trust proxy — number of proxy hops before the server
# Required for accurate IP extraction behind Nginx/Cloudflare
# Set to 1 if behind 1 proxy, 2 if behind Cloudflare + Nginx, etc.
TRUST_PROXY=1


# ──────────────────────────────────────────────────────────────────────────────
# CORS — cors.middleware.js
# Additional origins only needed for non-standard environments
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Extra allowed origin for staging/preview deployments
# EXTRA_ALLOWED_ORIGIN=https://preview.resqid.in


# ──────────────────────────────────────────────────────────────────────────────
# TOKEN & QR GENERATION
# Token model: token_hash (sha256), expires_at
# SchoolSettings: token_validity_months (default 12)
# ──────────────────────────────────────────────────────────────────────────────

# [OPTIONAL] Override default token validity in months (schema default: 12)
# TOKEN_VALIDITY_MONTHS=12

# [OPTIONAL] QR code default size in pixels (schema default: 512)
# QR_DEFAULT_SIZE_PX=512
