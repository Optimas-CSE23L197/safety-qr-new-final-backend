### Register School - BASIC plan
POST {{baseUrl}}/super-admin/schools
Content-Type: application/json
Authorization: Bearer {{super-adminToken}}

{
  "school": {
    "name": "Delhi Public School",
    "address": "Sector 18, Rohini",
    "city": "Delhi",
    "state": "Delhi",
    "pincode": "110085",
    "email": "contact@dpsrohini.edu.in",
    "phone": "+911127890123",
    "timezone": "Asia/Kolkata",
    "school_type": "PRIVATE"
  },
  "admin": {
    "name": "Rajesh Kumar",
    "email": "admin@dpsrohini.edu.in",
    "password": "TempPass@123"
  },
  "subscription": {
    "plan": "BASIC",
    "student_count": 500,
    "is_pilot": false
  },
  "agreement": {
    "agreed_via": "DASHBOARD",
    "ip_address": "103.58.92.10"
  }
}

