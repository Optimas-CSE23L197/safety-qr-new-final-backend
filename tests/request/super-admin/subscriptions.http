Content-Type: {{contentType}}


# =============================================================================
# 4. PATCH /subscriptions/:id  (Update Plan / Pricing)
# =============================================================================

### [HAPPY] Update — change plan BASIC → PREMIUM (with note)
PATCH {{baseUrl}}/{{trialingSubId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "plan": "PREMIUM",
  "unit_price_snapshot": 59900,
  "renewal_price_snapshot": 49900,
  "note": "School upgraded to Premium after demo — approved by ops team"
}

###

### [HAPPY] Update — enable custom pricing on CUSTOM plan
PATCH {{baseUrl}}/{{validSubId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "plan": "CUSTOM",
  "unit_price_snapshot": 39900,
  "renewal_price_snapshot": 35000,
  "is_custom_pricing": true,
  "custom_price_note": "Bulk deal — 900 students, negotiated by BD team",
  "note": "Custom pricing approved for large school"
}

###

### [HAPPY] Update — enable pilot mode
PATCH {{baseUrl}}/{{trialingSubId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "is_pilot": true,
  "pilot_expires_at": "2025-09-30T23:59:59.000Z",
  "note": "3-month pilot approved for government school partnership"
}

###

### [HAPPY] Update — extend current period end
PATCH {{baseUrl}}/{{activeSubId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "current_period_end": "2026-03-31T23:59:59.000Z",
  "note": "Period extended due to delayed card delivery"
}

###

### [HAPPY] Update — change advance percent
PATCH {{baseUrl}}/{{trialingSubId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "advance_percent": 30,
  "note": "Advance reduced to 30% for new government school"
}

###

### [EDGE] Update — empty body (no-op, should succeed or 422)
PATCH {{baseUrl}}/{{validSubId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{}

###

### [EDGE] Update — price change without note (should 422)
PATCH {{baseUrl}}/{{validSubId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "unit_price_snapshot": 45000
}

###

### [EDGE] Update — is_custom_pricing true without custom_price_note (should 422)
PATCH {{baseUrl}}/{{validSubId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

