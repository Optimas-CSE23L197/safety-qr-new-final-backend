# =============================================================================
# RESQID — Super Admin | Subscriptions Module HTTP Test Suite
# Covers: Happy Path, Attack Vectors, Edge Cases, Auth/RBAC Guards
# Tool: REST Client (VS Code) or IntelliJ HTTP Client
# =============================================================================

@baseUrl     = http://localhost:3000/api/super-admin/subscriptions
@contentType = application/json

# ─── Fill these after login ───────────────────────────────────────────────────
@accessToken     = PASTE_SUPER_ADMIN_ACCESS_TOKEN_HERE
@schoolAdminToken = PASTE_SCHOOL_ADMIN_ACCESS_TOKEN_HERE
@parentToken     = PASTE_PARENT_ACCESS_TOKEN_HERE

# ─── Fill these with real IDs from your DB ────────────────────────────────────
@validSubId    = PASTE_VALID_SUBSCRIPTION_ID_HERE
@activeSubId   = PASTE_ACTIVE_SUBSCRIPTION_ID_HERE
@trialingSubId = PASTE_TRIALING_SUBSCRIPTION_ID_HERE
@canceledSubId = PASTE_CANCELED_SUBSCRIPTION_ID_HERE
@expiredSubId  = PASTE_EXPIRED_SUBSCRIPTION_ID_HERE
@pastDueSubId  = PASTE_PAST_DUE_SUBSCRIPTION_ID_HERE


# =============================================================================
# 1. GET /subscriptions/stats
# =============================================================================

### [HAPPY] Stats — valid super admin
GET {{baseUrl}}/stats
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

###

### [ATTACK] Stats — no auth token
GET {{baseUrl}}/stats
Content-Type: {{contentType}}

###

### [ATTACK] Stats — school admin token (wrong role)
GET {{baseUrl}}/stats
Authorization: Bearer {{schoolAdminToken}}
Content-Type: {{contentType}}

###

### [ATTACK] Stats — parent token (wrong role)
GET {{baseUrl}}/stats
Authorization: Bearer {{parentToken}}
Content-Type: {{contentType}}

###

### [ATTACK] Stats — forged JWT (alg:none)
GET {{baseUrl}}/stats
Authorization: Bearer eyJhbGciOiJub25lIn0.eyJzdWIiOiJhdHRhY2tlciIsInJvbGUiOiJTVVBFUl9BRE1JTiJ9.
Content-Type: {{contentType}}

###

### [ATTACK] Stats — tampered role in JWT
GET {{baseUrl}}/stats
Authorization: Bearer eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c2VyMSIsInJvbGUiOiJTVVBFUl9BRE1JTiIsInNlc3Npb25JZCI6ImZha2UifQ.invalidsig
Content-Type: {{contentType}}

###

### [ATTACK] Stats — expired access token
GET {{baseUrl}}/stats
Authorization: Bearer PASTE_EXPIRED_TOKEN_HERE
Content-Type: {{contentType}}

###

### [ATTACK] Stats — HTTP verb tampering (POST on GET-only route)
POST {{baseUrl}}/stats
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}


