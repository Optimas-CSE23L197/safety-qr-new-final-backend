### ═══════════════════════════════════════════════════════════════════════════
### [F] SCAN LOG + DB INTEGRITY
### After each: SELECT * FROM "ScanLog" ORDER BY created_at DESC LIMIT 1;
### ═══════════════════════════════════════════════════════════════════════════

# [F-1] Tampered code — ScanLog sentinel UUID check
# EXPECTED DB row after this request:
#   token_id  = '00000000-0000-0000-0000-000000000000'
#   school_id = '00000000-0000-0000-0000-000000000000'
#   result    = 'INVALID'
# CONFIRMS: [FIX-4 service] — was crashing with FK error ("unknown" ≠ UUID)
GET {{BASE_URL}}{{SCAN_PATH}}/ZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZ1
User-Agent: ScanLogTest/1.0
X-Forwarded-For: 192.0.2.60
Accept: application/json

###

# [F-2] Nonexistent UUID — sentinel school_id check
# EXPECTED DB row:
#   token_id  = <the real decoded UUID — exists in ScanLog>
#   school_id = '00000000-0000-0000-0000-000000000000'
#   result    = 'INVALID'
GET {{BASE_URL}}{{SCAN_PATH}}/{{NON_EXISTENT_CODE}}
User-Agent: ScanLogTest/1.0
X-Forwarded-For: 192.0.2.61
Accept: application/json

###

# [F-3] REVOKED — verify school field leak is closed
# EXPECTED response: school = { name: "ResQid Test School" }
# MUST NOT contain: phone, address, logo_url
# If any of those appear → safeSchoolMinimal not used [FIX-3 service]
GET {{BASE_URL}}{{SCAN_PATH}}/{{REVOKED_CODE}}
User-Agent: ScanLogTest/1.0
X-Forwarded-For: 192.0.2.62
Accept: application/json

###

# [F-4] Blood group format check
# EXPECTED: profile.blood_group = "B+" (seed sets B_POS)
# WRONG:    "BPOS" or "B_POS" or "B POS"
# CONFIRMS: formatBloodGroup fix [FIX-6 service]
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: ScanLogTest/1.0
X-Forwarded-For: 192.0.2.63
Accept: application/json


