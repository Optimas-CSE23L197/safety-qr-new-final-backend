### =============================================================================
### scan.http — RESQID
### Complete test suite for GET /s/:code — public QR scan endpoint
###
### QUICK START (3 steps):
###   1. node tests/seed.scan.js
###   2. Copy the @variable block it prints into the section below
###   3. Run requests — in VS Code: install "REST Client" by Huachao Mao
###
### To reset and get fresh codes:
###   node tests/seed.scan.js --regen
###
### To clean up after testing:
###   node tests/seed.scan.js --clean
### =============================================================================

@BASE_URL = http://localhost:3000
@SCAN_PATH = /s

# ── PASTE SEED SCRIPT OUTPUT BELOW THIS LINE ──────────────────────────────────
# Run: node tests/seed.scan.js
# Then copy the printed block here and save the file.

@VALID_CODE           = IvMVixxZuUnlPXlckMHK83EjOv54x8OPgHFaQZVj54L
@MINIMAL_VIS_CODE     = MHMeLMjzMyNZUnQXQxEd79CHnpwMGNllBaE8HEYw4P7
@HIDDEN_VIS_CODE      = TsGuidlLKqsIfLWgj4OdEmfcsomIbx929Wi96MEczXa
@UNASSIGNED_CODE      = paBzheHwIcvnUzqYUkMG9HbuUcL5CRrADNp47BtckaY
@ISSUED_CODE          = HjHAqQzGgYCY2qxRv1aUdkZYgw0wqErfJS2XdFILUW0
@INACTIVE_CODE        = TB3WnkjxP5oYiDZvZhpoo3mKLZqSTFIcFjbdmnzR9UE
@REVOKED_CODE         = RcxhRm14FdwgT4QgCLR6EYjEjrI1MGisfOJh2xa2Cr0
@EXPIRED_CODE         = yP9X1sF7Lm0uIiBYCEE6S69yN3KJFC9ktoFZPrFBiC0
@NO_PROFILE_CODE      = 8RmIJUsudiUTdSP0jcYX7FltOh7QRGFry248xy03XqB
@NON_EXISTENT_CODE    = DKnhmImBdv5jBHNelRatQqDjkkxPrfJA9Ju58RJibHr

# ── END PASTE BLOCK ───────────────────────────────────────────────────────────


###
### ═══════════════════════════════════════════════════════════════════════════
### [A] HAPPY PATH — ACTIVE token, all 3 visibility levels
### Expected for all: HTTP 200, state="ACTIVE"
### ═══════════════════════════════════════════════════════════════════════════

# [A-1] PUBLIC visibility — full emergency profile
# CHECK: profile has blood_group, allergies, conditions, medications,
#        doctor { name, phone }, notes, contacts[] with decrypted phones
#        school has name + logo_url + phone + address
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: Mozilla/5.0 (iPhone; CPU iPhone OS 17_0) ResQidScanner/1.0
X-Forwarded-For: 203.0.113.10
Accept: application/json

###

# [A-2] MINIMAL visibility — name + photo + primary_contact only
# CHECK: profile has NO blood_group, allergies, conditions
#        profile.primary_contact.phone is a real phone number (decrypted)
#        profile has NO contacts[] array
GET {{BASE_URL}}{{SCAN_PATH}}/{{MINIMAL_VIS_CODE}}
User-Agent: Mozilla/5.0 (Android 14) ResQidScanner/1.0
X-Forwarded-For: 203.0.113.11
Accept: application/json

###

# [A-3] HIDDEN visibility — name + class only, nothing else
# CHECK: profile has NO contacts, NO medical, NO photo
#        school is safeSchoolFull (phone + address present — card is live)
GET {{BASE_URL}}{{SCAN_PATH}}/{{HIDDEN_VIS_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 203.0.113.12
Accept: application/json


###
### ═══════════════════════════════════════════════════════════════════════════
### [B] TOKEN STATES — one per status, verify exact response shape
### ═══════════════════════════════════════════════════════════════════════════

# [B-1] UNASSIGNED — card not yet registered by parent
# CHECK: state="UNREGISTERED"
#        nonce present (32-char hex string)
#        nonceExpiresAt ≈ now + 15 min
#        school is safeSchoolFull (phone + address visible)
GET {{BASE_URL}}{{SCAN_PATH}}/{{UNASSIGNED_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 203.0.113.20
Accept: application/json

###

# [B-1b] UNASSIGNED — scan again immediately (nonce deduplication test)
# CHECK: nonce value is IDENTICAL to B-1 — not a new value
#        Run: SELECT COUNT(*) FROM "RegistrationNonce" WHERE token_id='<id>'
#        Must be 1 — not 2
GET {{BASE_URL}}{{SCAN_PATH}}/{{UNASSIGNED_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 203.0.113.20
Accept: application/json

###

# [B-2] ISSUED — linked to student, not yet activated by family
# CHECK: state="ISSUED"
#        school present, no profile, no nonce
GET {{BASE_URL}}{{SCAN_PATH}}/{{ISSUED_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 203.0.113.21
Accept: application/json

###

# [B-3] INACTIVE — temporarily disabled
# CHECK: state="INACTIVE"
#        school is safeSchoolFull (reversible state — card may return)
GET {{BASE_URL}}{{SCAN_PATH}}/{{INACTIVE_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 203.0.113.22
Accept: application/json

###

# [B-4] REVOKED — permanently cancelled ← KEY SECURITY CHECK
# CHECK: state="REVOKED"
#        school has ONLY { name } — NO phone, NO address, NO logo_url
#        This is safeSchoolMinimal [FIX-3 service]
#        Verify by inspecting response body carefully
GET {{BASE_URL}}{{SCAN_PATH}}/{{REVOKED_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 203.0.113.23
Accept: application/json

###

# [B-5] EXPIRED — past expires_at date
# CHECK: state="EXPIRED"
#        school has ONLY { name } — NO phone, NO address [FIX-3 service]
#        message mentions renewing with school
GET {{BASE_URL}}{{SCAN_PATH}}/{{EXPIRED_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 203.0.113.24
Accept: application/json

###

# [B-6] NO_PROFILE — ACTIVE token but student.is_active=false
# CHECK: state="NO_PROFILE"
#        school present (safeSchoolFull)
#        no profile block
GET {{BASE_URL}}{{SCAN_PATH}}/{{NO_PROFILE_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 203.0.113.25
Accept: application/json


###
### ═══════════════════════════════════════════════════════════════════════════
### [C] CRYPTO REJECTION — all must be rejected without touching DB
###     Watch your DB query log — none of these should produce a Token lookup
### ═══════════════════════════════════════════════════════════════════════════

# [C-1] Old 28-char format (previous HMAC-injection scheme)
# EXPECTED: HTTP 400 — route regex rejects before controller runs
GET {{BASE_URL}}{{SCAN_PATH}}/5YbX2mKqf3AB9xP9nRtL3vWcUjAe
User-Agent: ResQidScanner/1.0
Accept: application/json

###

# [C-2] 42 chars — one short of 43
# EXPECTED: HTTP 400
GET {{BASE_URL}}{{SCAN_PATH}}/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
User-Agent: ResQidScanner/1.0
Accept: application/json

###

# [C-3] 44 chars — one too long
# EXPECTED: HTTP 400
GET {{BASE_URL}}{{SCAN_PATH}}/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
User-Agent: ResQidScanner/1.0
Accept: application/json

###

# [C-4] Invalid chars (hyphen) — correct length but bad alphabet
# EXPECTED: HTTP 400 — route regex rejects non-alphanumeric
GET {{BASE_URL}}{{SCAN_PATH}}/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA-
User-Agent: ResQidScanner/1.0
Accept: application/json

###

# [C-5] All zeros — 43 chars, valid base62, passes regex
# EXPECTED: HTTP 200, state="INVALID" — AES-SIV auth tag mismatch
#           Verify NO DB query fired (check pg_stat_activity or query logs)
GET {{BASE_URL}}{{SCAN_PATH}}/0000000000000000000000000000000000000000000
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 192.0.2.1
Accept: application/json

###

# [C-6] All uppercase A — 43 chars, valid base62
# EXPECTED: HTTP 200, state="INVALID"
GET {{BASE_URL}}{{SCAN_PATH}}/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 192.0.2.2
Accept: application/json

###

# [C-7] Valid code for a UUID that doesn't exist in Token table
# (seed script prints this as @NON_EXISTENT_CODE)
# EXPECTED: HTTP 200, state="INVALID"
#           DB IS queried (crypto passes), but findUnique returns null
#           ScanLog written with sentinel school_id [FIX-4 service]
GET {{BASE_URL}}{{SCAN_PATH}}/{{NON_EXISTENT_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 192.0.2.3
Accept: application/json

###

# [C-8] Empty segment
# EXPECTED: HTTP 404 from Express (no route matches)
GET {{BASE_URL}}{{SCAN_PATH}}/
User-Agent: ResQidScanner/1.0
Accept: application/json

###

# [C-9] SQL injection — rejected by route regex (bad chars)
# EXPECTED: HTTP 400
GET {{BASE_URL}}{{SCAN_PATH}}/' OR '1'='1
User-Agent: ResQidScanner/1.0
Accept: application/json

###

# [C-10] Path traversal
# EXPECTED: HTTP 400 or 404
GET {{BASE_URL}}{{SCAN_PATH}}/../../../etc/passwd
User-Agent: ResQidScanner/1.0
Accept: application/json


###
### ═══════════════════════════════════════════════════════════════════════════
### [D] RATE LIMITING — three independent layers
### ═══════════════════════════════════════════════════════════════════════════

# [D-1] IP rate limit — publicEmergencyLimiter (10/min per IP)
# HOW TO TEST: In VS Code REST Client, right-click → "Send All Requests"
#              on this block (repeat it 11 times manually or use a script)
# EXPECTED: Requests 1–10 → HTTP 200
#           Request 11    → HTTP 429 "Too many requests — please slow down"
#           requestId present in 429 body
# CONFIRMS: redis.sendCommand fix [FIX-1 rateLimit] — was broken before
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 10.0.0.100
Accept: application/json

###

# [D-2] Per-token rate limit — perTokenScanLimit (20/hr per scan code)
# HOW TO TEST: Use a different IP from D-1 (so IP limit doesn't interfere)
#              Send 21 times. Each time a different XFF to bypass IP limit.
# EXPECTED: Requests 1–20 → HTTP 200
#           Request 21    → HTTP 429 "This QR code has been scanned too many times"
# CONFIRMS: req.params.code fix [FIX-2 rateLimit] — was req.params.token before
# VERIFY:   SELECT * FROM "ScanRateLimit" WHERE identifier = '<VALID_CODE_VALUE>'
#             AND identifier_type = 'TOKEN';
#           Should have a row with blocked_until set
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 10.0.1.1
Accept: application/json

###

# [D-3] Persistent IP block — checkIpBlocked (DB-backed)
# SETUP: Run this SQL first:
#   INSERT INTO "ScanRateLimit"
#     (id, identifier, identifier_type, count, window_start, last_hit,
#      blocked_until, blocked_reason, block_count)
#   VALUES
#     (gen_random_uuid(), '172.16.0.99', 'IP', 25, now(), now(),
#      now() + interval '1 hour', 'Manual test block', 1)
#   ON CONFLICT (identifier, identifier_type) DO UPDATE
#     SET blocked_until = now() + interval '1 hour';
#
# EXPECTED: HTTP 403 "IP address is temporarily blocked"
# CONFIRMS: checkIpBlocked fires BEFORE publicEmergencyLimiter (first in chain)
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 172.16.0.99
Accept: application/json

###

# [D-4] Rate limit is per-IP — different IPs should all succeed independently
# All three should return HTTP 200 (each IP has its own Redis window)
# If any returns 429: rate limit is global (bug)
GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 198.51.100.1
Accept: application/json

###

GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 198.51.100.2
Accept: application/json

###

GET {{BASE_URL}}{{SCAN_PATH}}/{{VALID_CODE}}
User-Agent: ResQidScanner/1.0
X-Forwarded-For: 198.51.100.3
Accept: application/json


