// =============================================================================
// RESQID — coreZ Technologies Pvt. Ltd.
// PRODUCTION-GRADE SCHEMA v4.0
// ─────────────────────────────────────────────────────────────────────────────
// v4.0 FIXES (13 total):
//   [F01] CardOrder delivery fields → nullable (CALL orders filled later)
//   [F02] Payment.subscription_id → nullable + order_id added
//   [F03] ParentEditLog.school_id → nullable (parent edits before school)
//   [F04] Token.order_id + order_item_id → full traceability
//   [F05] CardOrderItem → Token @relation added (FK enforced)
//   [F06] Invoice model added (was referenced but missing)
//   [F07] TokenBatch.order_id → link batch to order
//   [F08] Notification → ParentUser @relation properly defined
//   [F09] SchoolSettings school_hours added (powers AFTER_HOURS anomaly)
//   [F10] ScanRateLimit.blocked_reason + block_count added
//   [F11] QrFormat enum replaces String
//   [F12] CardTemplate.updated_by added
//   [F13] CardOrder → TokenBatch relation added
// =============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AppTheme {
  LIGHT
  DARK
  SYSTEM
}

enum ProfileType {
  STUDENT       // Phase 1 ✅
  ELDERLY       // Phase 2 — Alzheimer patients
  PET           // Phase 3
  INDIVIDUAL    // Phase 4 — self-registered
}

enum SetupStage {
  PENDING       // just registered — empty block
  BASIC         // name + photo added
  COMPLETE      // emergency profile filled
  VERIFIED      // school has verified
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
  UNKNOWN
}

enum TokenStatus {
