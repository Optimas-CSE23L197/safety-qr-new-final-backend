generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// SCHOOL
// Changes:
//   - Removed: pricing_tier (belongs to Subscription, not School)
//   - Added:   setup_status, activated_at
//   - Added:   agreements relation
// ─────────────────────────────────────────────────────────────
model School {
  id                     String              @id @default(uuid())
  name                   String
  address                String?
  city                   String?
  state                  String?
  pincode                String?
  country                String              @default("IN")
  code                   String              @unique           // auto-generated: DPS-DL-2025-4872
  serial_number          Int                 @unique @default(autoincrement())
  email                  String?
  phone                  String?
  logo_url               String?
  timezone               String              @default("Asia/Kolkata")
  school_type            SchoolType          @default(PRIVATE)  // classification, never changes
  udise_code             String?             @unique
  affiliation_num        String?
  affiliated_board       String?
  contract_signed_at     DateTime?
  contract_expires_at    DateTime?
  onboarded_by           String?                               // superadmin ID
  onboarded_at           DateTime?
  setup_status           SchoolSetupStatus   @default(PENDING_SETUP) // NEW
  activated_at           DateTime?                             // NEW: when first admin accepted invite
  is_active              Boolean             @default(true)
  created_at             DateTime            @default(now())
  updated_at             DateTime            @updatedAt

  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  cards                  Card[]
  cardOrders             CardOrder[]
  cardRenewals           CardRenewal[]
  cardTemplate           CardTemplate?
  dashboardNotifications DashboardNotification[]
  invoices               Invoice[]
  locationEvents         LocationEvent[]
  notifications          Notification[]
  parentEditLogs         ParentEditLog[]
  payments               Payment[]
  qrAssets               QrAsset[]
  scanLogs               ScanLog[]
  featureFlags           SchoolFeatureFlag[]
  settings               SchoolSettings?
  users                  SchoolUser[]
  students               Student[]
  subscriptions          Subscription[]
  agreements             SchoolAgreement[]   // NEW
  tokens                 Token[]
  tokenBatches           TokenBatch[]
  trustedScanZones       TrustedScanZone[]
  webhooks               Webhook[]

  @@index([code])
  @@index([is_active])
  @@index([serial_number])
  @@index([setup_status])  // NEW
  @@index([school_type])   // NEW: useful for reports
}

// ─────────────────────────────────────────────────────────────
// SCHOOL SETTINGS — no changes
// ─────────────────────────────────────────────────────────────
model SchoolSettings {
  id                         String            @id @default(uuid())
  school_id                  String            @unique
  allow_location             Boolean           @default(false)
  allow_parent_edit          Boolean           @default(true)
  scan_notifications_enabled Boolean           @default(true)
  notify_on_every_scan       Boolean           @default(false)
  scan_alert_cooldown_mins   Int               @default(60)
  token_validity_months      Int               @default(12)
  max_tokens_per_student     Int               @default(1)
  default_profile_visibility ProfileVisibility @default(PUBLIC)
  renewal_reminder_days      Int[]             @default([30, 15, 7, 1])
  auto_deactivate_on_expiry  Boolean           @default(true)
  school_hours_start         String            @default("08:00")
  school_hours_end           String            @default("17:00")
  school_days                Int[]             @default([1, 2, 3, 4, 5])
  created_at                 DateTime          @default(now())
  updated_at                 DateTime          @updatedAt
  school                     School            @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([allow_location])
}

// ─────────────────────────────────────────────────────────────
// SCHOOL USER
// Changes:
//   - Added: is_primary, invited_by, invite_sent_at,
//            invite_accepted_at, must_change_password
//   - Removed nothing (password_hash stays — superadmin sets it directly)
// ─────────────────────────────────────────────────────────────
model SchoolUser {
  id                     String                  @id @default(uuid())
  school_id              String
  email                  String                  @unique
  password_hash          String                  // superadmin sets this; user changes via dashboard
  name                   String?
  role                   SchoolRole              @default(ADMIN)
  is_primary             Boolean                 @default(false)  // NEW: primary contact person
  is_active              Boolean                 @default(true)
  must_change_password   Boolean                 @default(true)   // NEW: forced on first login
  invited_by             String?                                  // NEW: superadmin ID who created
  invite_sent_at         DateTime?                                // NEW: when credentials email was sent
  invite_accepted_at     DateTime?                                // NEW: when they first logged in
  last_login_at          DateTime?
  created_at             DateTime                @default(now())
  updated_at             DateTime                @updatedAt
  dashboardNotifications DashboardNotification[]
  school                 School                  @relation(fields: [school_id], references: [id], onDelete: Cascade)
  sessions               Session[]

  @@index([school_id])
  @@index([is_primary])   // NEW
}

// ─────────────────────────────────────────────────────────────
// PARENT USER — no changes
// ─────────────────────────────────────────────────────────────
model ParentUser {
  id                 String                  @id @default(uuid())
  email              String?                 @unique
  phone              String                  @unique
  phone_index        String?                 @unique
  name               String?
  avatar_url         String?
  preferred_language String                  @default("en")
  preferred_theme    AppTheme                @default(SYSTEM)
  is_phone_verified  Boolean                 @default(false)
  is_email_verified  Boolean                 @default(false)
  status             UserStatus              @default(ACTIVE)
  last_login_at      DateTime?
  deleted_at         DateTime?
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  active_student_id  String?
  deviceLoginLogs    DeviceLoginLog[]
  notifications      Notification[]
  devices            ParentDevice[]
  editLogs           ParentEditLog[]
  notificationPrefs  ParentNotificationPref?
  children           ParentStudent[]
  sessions           Session[]
  activeStudent      Student?  @relation("ActiveStudent", fields: [active_student_id], references: [id])

  @@index([phone_index])
}

// ─────────────────────────────────────────────────────────────
// PARENT DEVICE — no changes
// ─────────────────────────────────────────────────────────────
model ParentDevice {
  id                 String              @id @default(uuid())
  parent_id          String
  platform           DevicePlatform
  device_name        String?
  device_model       String?
  device_fingerprint String?   @unique
  os_version         String?
  app_version        String?
  is_active          Boolean             @default(true)
  last_seen_at       DateTime?
  logged_out_at      DateTime?
  logout_reason      DeviceLogoutReason?
  created_at         DateTime            @default(now())
  expo_push_token    String?             @unique
  parent             ParentUser          @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@index([parent_id, is_active])
}

// ─────────────────────────────────────────────────────────────
// PARENT NOTIFICATION PREF — no changes
// ─────────────────────────────────────────────────────────────
model ParentNotificationPref {
  id                        String     @id @default(uuid())
  parent_id                 String     @unique
  scan_notify_enabled       Boolean    @default(true)
  scan_notify_push          Boolean    @default(true)
  scan_notify_sms           Boolean    @default(false)
  scan_notify_email         Boolean    @default(false)
  anomaly_notify_enabled    Boolean    @default(true)
  anomaly_notify_push       Boolean    @default(true)
  anomaly_notify_sms        Boolean    @default(true)
  anomaly_notify_email      Boolean    @default(true)
  card_expiry_notify        Boolean    @default(true)
  card_blocked_notify       Boolean    @default(true)
  device_login_notify_email Boolean    @default(true)
  account_change_notify     Boolean    @default(true)
  quiet_hours_enabled       Boolean    @default(false)
  quiet_hours_start         String?
  quiet_hours_end           String?
  created_at                DateTime   @default(now())
  updated_at                DateTime   @updatedAt
  parent                    ParentUser @relation(fields: [parent_id], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// SUPER ADMIN — no changes
// ─────────────────────────────────────────────────────────────
model SuperAdmin {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String                  @unique
  password_hash          String
  is_active              Boolean                 @default(true)
  last_login_at          DateTime?
  created_at             DateTime                @default(now())
  updated_at             DateTime                @updatedAt
  dashboardNotifications DashboardNotification[]
  sessions               Session[]

  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// OTP AUDIT LOG — no changes
// ─────────────────────────────────────────────────────────────
model OtpAuditLog {
  id           String     @id @default(uuid())
  purpose      OtpPurpose
  attempts     Int        @default(0)
  max_attempts Int        @default(5)
  verified     Boolean    @default(false)
  verified_at  DateTime?
  expires_at   DateTime
  invalidated  Boolean    @default(false)
  msg91_req_id String?
  ip_address   String?
  created_at   DateTime   @default(now())
  phone_index  String

  @@index([phone_index, purpose])
  @@index([expires_at])
}

// ─────────────────────────────────────────────────────────────
// STUDENT — no changes
// ─────────────────────────────────────────────────────────────
model Student {
  id                    String            @id @default(uuid())
  school_id             String?
  profile_type          ProfileType       @default(STUDENT)
  setup_stage           SetupStage        @default(PENDING)
  first_name            String?
  last_name             String?
  photo_url             String?
  gender                Gender?
  dob_encrypted         String?
  class                 String?
  section               String?
  roll_number           String?
  admission_number      String?
  is_active             Boolean           @default(true)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt
  deleted_at            DateTime?
  card_design_url       String?
  card_number           String?           @unique
  design_completed_at   DateTime?
  design_started_at     DateTime?
  design_status         DesignStatus?     @default(PENDING)
  pipeline_completed_at DateTime?
  pipeline_started_at   DateTime?
  pipeline_status       PipelineStatus?   @default(PENDING)
  qr_code_url           String?
  scan_url              String?
  token                 String?           @unique
  token_hash            String?           @unique
  claimed_at            DateTime?
  cards                 Card[]
  orderItems            CardOrderItem[]
  cardRenewals          CardRenewal[]
  cardVisibility        CardVisibility?
  emergency             EmergencyProfile?
  locationConsent       LocationConsent?
  locationEvents        LocationEvent[]
  notifications         Notification[]
  editLogs              ParentEditLog[]
  parents               ParentStudent[]
  scanLogs              ScanLog[]
  school                School?           @relation(fields: [school_id], references: [id])
  tokens                Token[]
  activeForParents   ParentUser[]  @relation("ActiveStudent")

  @@index([school_id])
  @@index([setup_stage])
  @@index([pipeline_status])
  @@index([card_number])
  @@index([token_hash])
}

// ─────────────────────────────────────────────────────────────
// PARENT STUDENT
// ─────────────────────────────────────────────────────────────
model ParentStudent {
  id           String     @id @default(uuid())
  parent_id    String
  student_id   String
  relationship String?
  is_primary   Boolean    @default(false)
  linked_at       DateTime   @default(now())
  parent       ParentUser @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, student_id])
  @@index([parent_id])
}

// ─────────────────────────────────────────────────────────────
// EMERGENCY PROFILE — no changes
// ─────────────────────────────────────────────────────────────
model EmergencyProfile {
  id                     String             @id @default(uuid())
  student_id             String             @unique
  blood_group            BloodGroup?
  allergies              String?
  conditions             String?
  medications            String?
  doctor_name            String?
  doctor_phone_encrypted String?
  notes                  String?
  visibility             ProfileVisibility  @default(PUBLIC)
  is_visible             Boolean            @default(true)
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  contacts               EmergencyContact[]
  student                Student            @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// EMERGENCY CONTACT — no changes
// ─────────────────────────────────────────────────────────────
model EmergencyContact {
  id               String           @id @default(uuid())
  profile_id       String
  name             String
  phone_encrypted  String
  relationship     String?
  priority         Int
  display_order    Int              @default(0)
  is_active        Boolean          @default(true)
  call_enabled     Boolean          @default(true)
  whatsapp_enabled Boolean          @default(true)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  profile          EmergencyProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, priority])
  @@index([profile_id])
}

// ─────────────────────────────────────────────────────────────
// CARD VISIBILITY — no changes
// ─────────────────────────────────────────────────────────────
model CardVisibility {
  id                String            @id @default(uuid())
  student_id        String            @unique
  visibility        ProfileVisibility @default(PUBLIC)
  hidden_fields     String[]          @default([])
  updated_by_parent Boolean           @default(false)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  student           Student           @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// PARENT EDIT LOG — no changes
// ─────────────────────────────────────────────────────────────
model ParentEditLog {
  id          String         @id @default(uuid())
  school_id   String?
  student_id  String
  parent_id   String
  field_group ParentEditType
  old_value   Json?
  new_value   Json
  ip_address  String?
  user_agent  String?
  created_at  DateTime       @default(now())
  parent      ParentUser     @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  school      School?        @relation(fields: [school_id], references: [id])
  student     Student        @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
  @@index([parent_id])
  @@index([created_at])
}

// ─────────────────────────────────────────────────────────────
// TOKEN — no changes
// ─────────────────────────────────────────────────────────────
model Token {
  id             String              @id @default(uuid())
  school_id      String
  student_id     String?
  token_hash     String              @unique
  status         TokenStatus         @default(UNASSIGNED)
  batch_id       String?
  order_id       String?
  order_item_id  String?             @unique
  replaced_by_id String?
  activated_at   DateTime?
  assigned_at    DateTime?
  expires_at     DateTime?
  revoked_at     DateTime?
  created_at     DateTime            @default(now())
  is_honeypot    Boolean             @default(false)
  cards          Card[]
  locations      LocationEvent[]
  qrAsset        QrAsset?
  nonces         RegistrationNonce[]
  anomalies      ScanAnomaly[]
  scans          ScanLog[]
  batch          TokenBatch?         @relation(fields: [batch_id], references: [id])
  order          CardOrder?          @relation(fields: [order_id], references: [id])
  orderItem      CardOrderItem?      @relation(fields: [order_item_id], references: [id])
  replacedBy     Token?              @relation("TokenReplacement", fields: [replaced_by_id], references: [id])
  replacements   Token[]             @relation("TokenReplacement")
  school         School              @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student        Student?            @relation(fields: [student_id], references: [id])

  @@index([is_honeypot])
  @@index([school_id, status])
  @@index([order_id])
  @@index([token_hash])
  @@index([student_id])
}

// ─────────────────────────────────────────────────────────────
// TOKEN BATCH — no changes
// ─────────────────────────────────────────────────────────────
model TokenBatch {
  id              String           @id @default(uuid())
  school_id       String
  order_id        String?
  count           Int
  generated_count Int              @default(0)
  failed_count    Int              @default(0)
  status          TokenBatchStatus @default(PENDING)
  created_by      String
  notes           String?
  completed_at    DateTime?
  error_log       Json?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  tokens          Token[]
  order           CardOrder?       @relation(fields: [order_id], references: [id])
  school          School           @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// QR ASSET — no changes
// ─────────────────────────────────────────────────────────────
model QrAsset {
  id           String     @id @default(uuid())
  token_id     String     @unique
  school_id    String
  storage_key  String     @unique
  public_url   String
  format       QrFormat   @default(PNG)
  width_px     Int        @default(512)
  height_px    Int        @default(512)
  file_size_kb Int?
  qr_type      QrType
  generated_by String
  order_id     String?
  is_active    Boolean    @default(true)
  generated_at DateTime   @default(now())
  order        CardOrder? @relation(fields: [order_id], references: [id])
  school       School     @relation(fields: [school_id], references: [id], onDelete: Cascade)
  token        Token      @relation(fields: [token_id], references: [id], onDelete: Cascade)

  @@index([school_id])
  @@index([order_id])
}

// ─────────────────────────────────────────────────────────────
// CARD ORDER — no changes
// ─────────────────────────────────────────────────────────────
model CardOrder {
  id                       String                  @id @default(uuid())
  school_id                String
  subscription_id          String?
  order_number             String                  @unique
  order_type               OrderType
  status                   OrderStatus             @default(PENDING)
  payment_status           OrderPaymentStatus      @default(UNPAID)
  advance_amount           Int?
  advance_paid_at          DateTime?
  balance_amount           Int?
  balance_paid_at          DateTime?
  delivery_name            String?
  delivery_phone           String?
  delivery_address         String?
  delivery_city            String?
  delivery_state           String?
  delivery_pincode         String?
  caller_name              String?
  caller_phone             String?
  call_notes               String?
  notes                    String?
  admin_notes              String?
  confirmed_by             String?
  confirmed_at             DateTime?
  tokens_generated_by      String?
  tokens_generated_at      DateTime?
  card_design_files        Json?
  card_design_by           String?
  card_design_at           DateTime?
  vendor_id                String?
  vendor_notes             String?
  files_sent_to_vendor_at  DateTime?
  files_sent_by            String?
  print_complete_at        DateTime?
  print_complete_noted_by  String?
  status_changed_by        String?
  status_changed_at        DateTime?
  status_note              String?
  created_at               DateTime                @default(now())
  updated_at               DateTime                @updatedAt
  grand_total              Int?
  unit_price               Int?
  order_channel            OrderChannel?
  design_completed_count   Int                     @default(0)
  design_started_at        DateTime?
  final_invoice_id         String?                 @unique
  partial_invoice_id       String?                 @unique
  pipeline_completed_count Int                     @default(0)
  pipeline_started_at      DateTime?
  student_count            Int
  cards                    Card[]
  finalInvoice             Invoice?                @relation("FinalInvoiceForOrder", fields: [final_invoice_id], references: [id])
  partialInvoice           Invoice?                @relation("PartialInvoiceForOrder", fields: [partial_invoice_id], references: [id])
  school                   School                  @relation(fields: [school_id], references: [id], onDelete: Cascade)
  subscription             Subscription?           @relation(fields: [subscription_id], references: [id])
  vendor                   VendorProfile?          @relation(fields: [vendor_id], references: [id])
  items                    CardOrderItem[]
  dashboardNotifications   DashboardNotification[]
  invoices                 Invoice[]
  pipeline                 OrderPipeline?
  shipment                 OrderShipment?
  statusLogs               OrderStatusLog[]
  payments                 Payment[]
  qrAssets                 QrAsset[]
  tokens                   Token[]
  tokenBatches             TokenBatch[]

  @@index([school_id])
  @@index([status])
  @@index([payment_status])
  @@index([created_at])
}

// ─────────────────────────────────────────────────────────────
// CARD ORDER ITEM — no changes
// ─────────────────────────────────────────────────────────────
model CardOrderItem {
  id              String          @id @default(uuid())
  order_id        String
  student_id      String?
  token_id        String?         @unique
  student_name    String
  class           String?
  section         String?
  roll_number     String?
  photo_url       String?
  status          OrderItemStatus @default(PENDING)
  card_design_url String?
  card_printed    Boolean         @default(false)
  has_issue       Boolean         @default(false)
  issue_note      String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  pipeline_status PipelineStatus  @default(PENDING)
  order           CardOrder       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  student         Student?        @relation(fields: [student_id], references: [id])
  token           Token?

  @@index([order_id])
  @@index([student_id])
}

// ─────────────────────────────────────────────────────────────
// ORDER STATUS LOG — no changes
// ─────────────────────────────────────────────────────────────
model OrderStatusLog {
  id          String       @id @default(uuid())
  order_id    String
  from_status OrderStatus?
  to_status   OrderStatus
  changed_by  String
  note        String?
  metadata    Json?
  created_at  DateTime     @default(now())
  actor_type  ActorType    @default(SYSTEM)
  order       CardOrder    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id, created_at])
}

// ─────────────────────────────────────────────────────────────
// ORDER SHIPMENT — no changes
// ─────────────────────────────────────────────────────────────
model OrderShipment {
  id                     String            @id @default(uuid())
  order_id               String            @unique
  shiprocket_order_id    String?
  shiprocket_shipment_id String?
  awb_code               String?           @unique
  courier_name           String?
  courier_id             Int?
  tracking_url           String?
  label_url              String?
  manifest_url           String?
  pickup_vendor_id       String?
  pickup_name            String?
  pickup_contact         String?
  pickup_address         String?
  pickup_city            String?
  pickup_state           String?
  pickup_pincode         String?
  delivery_name          String?
  delivery_phone         String?
  delivery_address       String?
  delivery_city          String?
  delivery_state         String?
  delivery_pincode       String?
  status                 ShipmentStatus    @default(PENDING)
  shiprocket_status      ShiprocketStatus?
  created_by             String?
  tracking_shared_at     DateTime?
  tracking_shared_by     String?
  pickup_scheduled_at    DateTime?
  picked_up_at           DateTime?
  estimated_delivery_at  DateTime?
  delivered_at           DateTime?
  delivery_confirmed_by  String?
  notes                  String?
  created_at             DateTime          @default(now())
  updated_at             DateTime          @updatedAt
  order                  CardOrder         @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([awb_code])
}

// ─────────────────────────────────────────────────────────────
// VENDOR PROFILE — no changes
// ─────────────────────────────────────────────────────────────
model VendorProfile {
  id                  String       @id @default(uuid())
  name                String
  contact_name        String?
  phone               String?
  email               String?
  status              VendorStatus @default(ACTIVE)
  address             String?
  city                String?
  state               String?
  pincode             String?
  gstin               String?
  speciality          String?
  avg_turnaround_days Int?
  notes               String?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt
  orders              CardOrder[]

  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// CARD — no changes
// ─────────────────────────────────────────────────────────────
model Card {
  id           String        @id @default(uuid())
  school_id    String
  student_id   String?
  token_id     String?
  order_id     String?
  card_number  String        @unique
  file_url     String?
  print_status PrintStatus   @default(PENDING)
  printed_at   DateTime?
  created_at   DateTime      @default(now())
  order        CardOrder?    @relation(fields: [order_id], references: [id])
  school       School        @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student      Student?      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  token        Token?        @relation(fields: [token_id], references: [id])
  renewals     CardRenewal[]

  @@index([school_id])
  @@index([token_id])
  @@index([order_id])
  @@index([card_number])
}

// ─────────────────────────────────────────────────────────────
// CARD RENEWAL
// Changes:
//   - Added:   subscription_id, unit_price_snapshot, invoice_id
//   - Removed: pricing_tier, school_type (redundant — derive from subscription)
// ─────────────────────────────────────────────────────────────
model CardRenewal {
  id                   String       @id @default(uuid())
  card_id              String
  student_id           String
  school_id            String
  subscription_id      String?                    // NEW: which subscription period
  renewed_by           String?
  renewer_type         ActorType    @default(SYSTEM) // changed default to SYSTEM (auto-renewal)
  old_expiry           DateTime
  new_expiry           DateTime
  unit_price_snapshot  Int                        // NEW: price locked at renewal time (paise)
  amount_paid          Int                        // before tax
  tax_amount           Int          @default(0)
  total_paid           Int          @default(0)   // NEW: amount_paid + tax_amount
  invoice_id           String?                    // NEW: which invoice triggered this renewal
  payment_id           String?
  created_at           DateTime     @default(now())
  card                 Card         @relation(fields: [card_id], references: [id], onDelete: Cascade)
  invoice              Invoice?     @relation(fields: [invoice_id], references: [id])   // NEW
  payment              Payment?     @relation("RenewalPayment", fields: [payment_id], references: [id])
  school               School       @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student              Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subscription         Subscription? @relation(fields: [subscription_id], references: [id]) // NEW

  @@index([card_id])
  @@index([student_id])
  @@index([subscription_id])  // NEW
  @@index([invoice_id])        // NEW
}

// ─────────────────────────────────────────────────────────────
// NEW: PRICING CONFIG
// Single source of truth for all plan prices.
// Only SuperAdmin manages this. Never read at runtime — only at
// subscription creation. All runtime pricing uses snapshots.
// ─────────────────────────────────────────────────────────────
model PricingConfig {
  id              String    @id @default(uuid())
  plan            PlanType  @unique
  label           String                          // "Basic Plan", "Premium Plan"
  unit_price      Int                             // per card per year (paise)
  renewal_price   Int                             // renewal per card per year (paise)
  advance_percent Int       @default(50)          // % charged upfront on order
  is_active       Boolean   @default(true)
  effective_from  DateTime  @default(now())
  notes           String?
  created_by      String?                         // superadmin ID
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@index([plan])
  @@index([is_active])
}

// ─────────────────────────────────────────────────────────────
// SUBSCRIPTION
// Changes:
//   - Removed: pricing_tier, unit_price (raw with hardcoded default)
//   - Added:   unit_price_snapshot, renewal_price_snapshot,
//              advance_percent, is_custom_pricing, custom_price_note,
//              custom_approved_by, custom_approved_at,
//              is_pilot, pilot_expires_at, pilot_converted_at,
//              active_card_count, total_invoiced, total_received,
//              balance_due, renewals relation
//   - Fixed:   plan default was GOVT_STANDARD — now no default,
//              must be explicitly set at creation
// ─────────────────────────────────────────────────────────────
model Subscription {
  id                      String             @id @default(uuid())
  school_id               String

  // Plan — locked at registration, only SuperAdmin can change via reprice
  plan                    PlanType
  status                  SubscriptionStatus @default(TRIALING)

  // Price snapshot — copied once at creation, NEVER changes after
  // For CUSTOM: set manually by SuperAdmin
  // For BASIC/PREMIUM: copied from PricingConfig
  unit_price_snapshot     Int                             // paise
  renewal_price_snapshot  Int                             // paise
  advance_percent         Int                @default(50) // % charged upfront

  // Custom pricing fields (only populated when plan = CUSTOM)
  is_custom_pricing       Boolean            @default(false)
  custom_price_note       String?            // "Bulk deal, 800 students"
  custom_approved_by      String?            // superadmin ID
  custom_approved_at      DateTime?

  // Pilot flag — replaces FREE_PILOT plan entirely
  is_pilot                Boolean            @default(false)
  pilot_expires_at        DateTime?
  pilot_converted_at      DateTime?          // when pilot → paid

  // Billing totals — auto maintained by updateSubscriptionTotals()
  student_count           Int                @default(0)  // confirmed on first order
  active_card_count       Int                @default(0)  // used for renewal calculation
  grand_total             Int                @default(0)  // unit_price_snapshot × student_count
  total_invoiced          Int                @default(0)  // sum of all non-cancelled invoices
  total_received          Int                @default(0)  // sum of SUCCESS payments
  balance_due             Int                @default(0)  // total_invoiced - total_received

  // Period
  current_period_start    DateTime
  current_period_end      DateTime
  trial_ends_at           DateTime?
  fully_paid_at           DateTime?

  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt

  school                  School             @relation(fields: [school_id], references: [id], onDelete: Cascade)
  cardOrders              CardOrder[]
  invoices                Invoice[]
  renewals                CardRenewal[]      // NEW
  agreements              SchoolAgreement[]  // NEW
  payments                Payment[]          // NEW

  @@index([school_id, status])
  @@index([status])
  @@index([current_period_end])  // NEW: for renewal cron queries
  @@index([is_pilot])            // NEW: for pilot tracking
}

// ─────────────────────────────────────────────────────────────
// INVOICE
// Changes:
//   - Removed: category, order_invoice_type, renewal_invoice_type
//              (collapsed into single invoice_type field)
//   - Added:   invoice_type, card_count, tax_percent,
//              subscription_id made required not nullable
//   - Fixed:   subscription_id was nullable with no relation properly
//              defined — now properly typed
// ─────────────────────────────────────────────────────────────
model Invoice {
  id             String        @id @default(uuid())
  school_id      String
  subscription_id String                             // required — every invoice belongs to a subscription
  order_id       String?                             // only for ORDER_ADVANCE and ORDER_FINAL types
  invoice_number String        @unique

  // Single clean type — replaces category + order_invoice_type + renewal_invoice_type
  invoice_type   InvoiceType

  // Calculation snapshot — all auto-filled by service, never manual
  student_count  Int           @default(0)           // for order invoices
  card_count     Int           @default(0)           // for renewal invoices
  unit_price     Int                                 // snapshot at invoice time (paise)
  amount         Int                                 // before tax (paise)
  tax_percent    Int           @default(18)          // GST %
  tax_amount     Int                                 // auto = amount × tax_percent / 100
  total_amount   Int                                 // amount + tax_amount

  status         InvoiceStatus @default(ISSUED)
  issued_at      DateTime      @default(now())
  due_at         DateTime?
  paid_at        DateTime?
  pdf_url        String?
  pdf_generated_at DateTime?
  notes          String?

  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  // Back-relations for CardOrder partial/final invoice shortcuts (kept for compatibility)
  finalOrder     CardOrder?    @relation("FinalInvoiceForOrder")
  partialOrder   CardOrder?    @relation("PartialInvoiceForOrder")

  order          CardOrder?    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  school         School        @relation(fields: [school_id], references: [id], onDelete: Cascade)
  subscription   Subscription  @relation(fields: [subscription_id], references: [id])
  payments       Payment[]
  renewals       CardRenewal[]  // NEW: renewals triggered by this invoice

  @@index([school_id])
  @@index([subscription_id])   // NEW
  @@index([order_id])
  @@index([invoice_type])      // replaces @@index([category, order_invoice_type])
  @@index([status])
  @@index([invoice_number])
  @@index([due_at])            // NEW: for overdue queries
}

// ─────────────────────────────────────────────────────────────
// PAYMENT
// Changes:
//   - Fixed:   order_id was required (String) — now optional (String?)
//              because renewal payments have no order
//   - Added:   subscription_id relation properly, recorded_by,
//              notes, updated_at
//   - Removed: is_advance (invoice_type already tells us this)
//   - Fixed:   invoice_id was nullable — kept nullable for legacy
//              but all new payments must have invoice_id
// ─────────────────────────────────────────────────────────────
model Payment {
  id              String        @id @default(uuid())
  school_id       String
  invoice_id      String                             // required — payment always against an invoice
  order_id        String?                            // optional reference only (go through invoice)
  subscription_id String?                            // for direct subscription payments

  amount          Int                                // paise — actual amount received
  payment_ref     String?       @unique              // bank ref / UPI ID — duplicate detection
  status          PaymentStatus @default(PENDING)
  payment_mode    PaymentMode   @default(BANK_TRANSFER)
  recorded_by     String                             // superadmin ID — all payments are manual
  notes           String?                            // any context about this payment
  metadata        Json?                              // extra data if needed

  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  renewals        CardRenewal[] @relation("RenewalPayment")
  invoice         Invoice       @relation(fields: [invoice_id], references: [id])
  order           CardOrder?    @relation(fields: [order_id], references: [id])
  school          School        @relation(fields: [school_id], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscription_id], references: [id])

  @@index([school_id])
  @@index([invoice_id])
  @@index([order_id])
  @@index([subscription_id])  // NEW
  @@index([status])           // NEW
  @@index([created_at])
  @@index([payment_ref])
}

