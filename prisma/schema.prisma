generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model School {
  id                     String                  @id @default(uuid())
  name                   String
  address                String?
  city                   String?
  state                  String?
  pincode                String?
  country                String                  @default("IN")
  code                   String                  @unique
  serial_number          Int                     @unique @default(autoincrement())
  email                  String?
  phone                  String?
  logo_url               String?
  timezone               String                  @default("Asia/Kolkata")
  school_type            SchoolType              @default(PRIVATE)
  pricing_tier           PricingTier             @default(PRIVATE_STANDARD)
  udise_code             String?                 @unique
  affiliation_num        String?
  affiliated_board       String?
  contract_signed_at     DateTime?
  contract_expires_at    DateTime?
  onboarded_by           String?
  onboarded_at           DateTime?
  is_active              Boolean                 @default(true)
  created_at             DateTime                @default(now())
  updated_at             DateTime                @updatedAt
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  cards                  Card[]
  cardOrders             CardOrder[]
  cardRenewals           CardRenewal[]
  cardTemplate           CardTemplate?
  dashboardNotifications DashboardNotification[]
  invoices               Invoice[]
  locationEvents         LocationEvent[]
  notifications          Notification[]
  parentEditLogs         ParentEditLog[]
  payments               Payment[]
  qrAssets               QrAsset[]
  scanLogs               ScanLog[]
  featureFlags           SchoolFeatureFlag[]
  settings               SchoolSettings?
  users                  SchoolUser[]
  students               Student[]
  subscriptions          Subscription[]
  tokens                 Token[]
  tokenBatches           TokenBatch[]
  trustedScanZones       TrustedScanZone[]
  webhooks               Webhook[]

  @@index([code])
  @@index([is_active])
  @@index([serial_number])
}

model SchoolSettings {
  id                         String            @id @default(uuid())
  school_id                  String            @unique
  allow_location             Boolean           @default(false)
  allow_parent_edit          Boolean           @default(true)
  scan_notifications_enabled Boolean           @default(true)
  notify_on_every_scan       Boolean           @default(false)
  scan_alert_cooldown_mins   Int               @default(60)
  token_validity_months      Int               @default(12)
  max_tokens_per_student     Int               @default(1)
  default_profile_visibility ProfileVisibility @default(PUBLIC)
  renewal_reminder_days      Int[]             @default([30, 15, 7, 1])
  auto_deactivate_on_expiry  Boolean           @default(true)
  school_hours_start         String            @default("08:00")
  school_hours_end           String            @default("17:00")
  school_days                Int[]             @default([1, 2, 3, 4, 5])
  created_at                 DateTime          @default(now())
  updated_at                 DateTime          @updatedAt
  school                     School            @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([allow_location])
}

model SchoolUser {
  id                     String                  @id @default(uuid())
  school_id              String
  email                  String                  @unique
  password_hash          String
  name                   String?
  role                   SchoolRole              @default(ADMIN)
  is_active              Boolean                 @default(true)
  last_login_at          DateTime?
  created_at             DateTime                @default(now())
  updated_at             DateTime                @updatedAt
  dashboardNotifications DashboardNotification[]
  school                 School                  @relation(fields: [school_id], references: [id], onDelete: Cascade)
  sessions               Session[]

  @@index([school_id])
}

model ParentUser {
  id                 String                  @id @default(uuid())
  email              String?                 @unique
  phone              String                  @unique
  phone_index        String?                 @unique
  password_hash      String?
  name               String?
  avatar_url         String?
  preferred_language String                  @default("en")
  preferred_theme    AppTheme                @default(SYSTEM)
  is_phone_verified  Boolean                 @default(false)
  is_email_verified  Boolean                 @default(false)
  status             UserStatus              @default(ACTIVE)
  last_login_at      DateTime?
  deleted_at         DateTime?
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  deviceLoginLogs    DeviceLoginLog[]
  notifications      Notification[]
  devices            ParentDevice[]
  editLogs           ParentEditLog[]
  notificationPrefs  ParentNotificationPref?
  children           ParentStudent[]
  sessions           Session[]

  @@index([phone_index])
}

model ParentDevice {
  id              String              @id @default(uuid())
  parent_id       String
  platform        DevicePlatform
  device_name     String?
  device_model    String?
  os_version      String?
  app_version     String?
  is_active       Boolean             @default(true)
  last_seen_at    DateTime?
  logged_out_at   DateTime?
  logout_reason   DeviceLogoutReason?
  created_at      DateTime            @default(now())
  expo_push_token String?             @unique
  parent          ParentUser          @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@index([parent_id, is_active])
}

model ParentNotificationPref {
  id                        String     @id @default(uuid())
  parent_id                 String     @unique
  scan_notify_enabled       Boolean    @default(true)
  scan_notify_push          Boolean    @default(true)
  scan_notify_sms           Boolean    @default(false)
  scan_notify_email         Boolean    @default(false)
  anomaly_notify_enabled    Boolean    @default(true)
  anomaly_notify_push       Boolean    @default(true)
  anomaly_notify_sms        Boolean    @default(true)
  anomaly_notify_email      Boolean    @default(true)
  card_expiry_notify        Boolean    @default(true)
  card_blocked_notify       Boolean    @default(true)
  device_login_notify_email Boolean    @default(true)
  account_change_notify     Boolean    @default(true)
  quiet_hours_enabled       Boolean    @default(false)
  quiet_hours_start         String?
  quiet_hours_end           String?
  created_at                DateTime   @default(now())
  updated_at                DateTime   @updatedAt
  parent                    ParentUser @relation(fields: [parent_id], references: [id], onDelete: Cascade)
}

model SuperAdmin {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String                  @unique
  password_hash          String
  is_active              Boolean                 @default(true)
  last_login_at          DateTime?
  created_at             DateTime                @default(now())
  updated_at             DateTime                @updatedAt
  dashboardNotifications DashboardNotification[]
  sessions               Session[]

  @@index([email])
}

model OtpAuditLog {
  id           String     @id @default(uuid())
  purpose      OtpPurpose
  attempts     Int        @default(0)
  max_attempts Int        @default(5)
  verified     Boolean    @default(false)
  verified_at  DateTime?
  expires_at   DateTime
  invalidated  Boolean    @default(false)
  msg91_req_id String?
  ip_address   String?
  created_at   DateTime   @default(now())
  phone_index  String

  @@index([phone_index, purpose])
  @@index([expires_at])
}

model Student {
  id                    String            @id @default(uuid())
  school_id             String?
  profile_type          ProfileType       @default(STUDENT)
  setup_stage           SetupStage        @default(PENDING)
  first_name            String?
  last_name             String?
  photo_url             String?
  gender                Gender?
  dob_encrypted         String?
  class                 String?
  section               String?
  roll_number           String?
  admission_number      String?
  is_active             Boolean           @default(true)
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt
  deleted_at            DateTime?
  card_design_url       String?
  card_number           String?           @unique
  design_completed_at   DateTime?
  design_started_at     DateTime?
  design_status         DesignStatus?     @default(PENDING)
  pipeline_completed_at DateTime?
  pipeline_started_at   DateTime?
  pipeline_status       PipelineStatus?   @default(PENDING)
  qr_code_url           String?
  scan_url              String?
  token                 String?           @unique
  token_hash            String?           @unique
  cards                 Card[]
  orderItems            CardOrderItem[]
  cardRenewals          CardRenewal[]
  cardVisibility        CardVisibility?
  emergency             EmergencyProfile?
  locationConsent       LocationConsent?
  locationEvents        LocationEvent[]
  notifications         Notification[]
  editLogs              ParentEditLog[]
  parents               ParentStudent[]
  scanLogs              ScanLog[]
  school                School?           @relation(fields: [school_id], references: [id])
  tokens                Token[]

  @@index([school_id])
  @@index([setup_stage])
  @@index([pipeline_status])
  @@index([card_number])
  @@index([token_hash])
}

model ParentStudent {
  id           String     @id @default(uuid())
  parent_id    String
  student_id   String
  relationship String?
  is_primary   Boolean    @default(false)
  created_at   DateTime   @default(now())
  parent       ParentUser @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, student_id])
}

model EmergencyProfile {
  id                     String             @id @default(uuid())
  student_id             String             @unique
  blood_group            BloodGroup?
  allergies              String?
  conditions             String?
  medications            String?
  doctor_name            String?
  doctor_phone_encrypted String?
  notes                  String?
  visibility             ProfileVisibility  @default(PUBLIC)
  is_visible             Boolean            @default(true)
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  contacts               EmergencyContact[]
  student                Student            @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model EmergencyContact {
  id               String           @id @default(uuid())
  profile_id       String
  name             String
  phone_encrypted  String
  relationship     String?
  priority         Int
  display_order    Int              @default(0)
  is_active        Boolean          @default(true)
  call_enabled     Boolean          @default(true)
  whatsapp_enabled Boolean          @default(true)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  profile          EmergencyProfile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@unique([profile_id, priority])
  @@index([profile_id])
}

model CardVisibility {
  id                String            @id @default(uuid())
  student_id        String            @unique
  visibility        ProfileVisibility @default(PUBLIC)
  hidden_fields     String[]          @default([])
  updated_by_parent Boolean           @default(false)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  student           Student           @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model ParentEditLog {
  id          String         @id @default(uuid())
  school_id   String?
  student_id  String
  parent_id   String
  field_group ParentEditType
  old_value   Json?
  new_value   Json
  ip_address  String?
  user_agent  String?
  created_at  DateTime       @default(now())
  parent      ParentUser     @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  school      School?        @relation(fields: [school_id], references: [id])
  student     Student        @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
  @@index([parent_id])
  @@index([created_at])
}

model Token {
  id             String              @id @default(uuid())
  school_id      String
  student_id     String?
  token_hash     String              @unique
  status         TokenStatus         @default(UNASSIGNED)
  batch_id       String?
  order_id       String?
  order_item_id  String?             @unique
  replaced_by_id String?
  activated_at   DateTime?
  assigned_at    DateTime?
  expires_at     DateTime?
  revoked_at     DateTime?
  created_at     DateTime            @default(now())
  is_honeypot    Boolean             @default(false)
  cards          Card[]
  locations      LocationEvent[]
  qrAsset        QrAsset?
  nonces         RegistrationNonce[]
  anomalies      ScanAnomaly[]
  scans          ScanLog[]
  batch          TokenBatch?         @relation(fields: [batch_id], references: [id])
  order          CardOrder?          @relation(fields: [order_id], references: [id])
  orderItem      CardOrderItem?      @relation(fields: [order_item_id], references: [id])
  replacedBy     Token?              @relation("TokenReplacement", fields: [replaced_by_id], references: [id])
  replacements   Token[]             @relation("TokenReplacement")
  school         School              @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student        Student?            @relation(fields: [student_id], references: [id])

  @@index([is_honeypot])
  @@index([school_id, status])
  @@index([order_id])
  @@index([token_hash])
  @@index([student_id])
}

model TokenBatch {
  id              String           @id @default(uuid())
  school_id       String
  order_id        String?
  count           Int
  generated_count Int              @default(0)
  failed_count    Int              @default(0)
  status          TokenBatchStatus @default(PENDING)
  created_by      String
  notes           String?
  completed_at    DateTime?
  error_log       Json?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  tokens          Token[]
  order           CardOrder?       @relation(fields: [order_id], references: [id])
  school          School           @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([status])
}

model QrAsset {
  id           String     @id @default(uuid())
  token_id     String     @unique
  school_id    String
  storage_key  String     @unique
  public_url   String
  format       QrFormat   @default(PNG)
  width_px     Int        @default(512)
  height_px    Int        @default(512)
  file_size_kb Int?
  qr_type      QrType
  generated_by String
  order_id     String?
  is_active    Boolean    @default(true)
  generated_at DateTime   @default(now())
  order        CardOrder? @relation(fields: [order_id], references: [id])
  school       School     @relation(fields: [school_id], references: [id], onDelete: Cascade)
  token        Token      @relation(fields: [token_id], references: [id], onDelete: Cascade)

  @@index([school_id])
  @@index([order_id])
}

model CardOrder {
  id                       String                  @id @default(uuid())
  school_id                String
  subscription_id          String?
  order_number             String                  @unique
  order_type               OrderType
  status                   OrderStatus             @default(PENDING)
  payment_status           OrderPaymentStatus      @default(UNPAID)
  advance_amount           Int?
  advance_paid_at          DateTime?
  balance_amount           Int?
  balance_paid_at          DateTime?
  delivery_name            String?
  delivery_phone           String?
  delivery_address         String?
  delivery_city            String?
  delivery_state           String?
  delivery_pincode         String?
  caller_name              String?
  caller_phone             String?
  call_notes               String?
  notes                    String?
  admin_notes              String?
  confirmed_by             String?
  confirmed_at             DateTime?
  tokens_generated_by      String?
  tokens_generated_at      DateTime?
  card_design_files        Json?
  card_design_by           String?
  card_design_at           DateTime?
  vendor_id                String?
  vendor_notes             String?
  files_sent_to_vendor_at  DateTime?
  files_sent_by            String?
  print_complete_at        DateTime?
  print_complete_noted_by  String?
  status_changed_by        String?
  status_changed_at        DateTime?
  status_note              String?
  created_at               DateTime                @default(now())
  updated_at               DateTime                @updatedAt
  grand_total              Int?
  unit_price               Int?
  order_channel            OrderChannel?
  design_completed_count   Int                     @default(0)
  design_started_at        DateTime?
  final_invoice_id         String?                 @unique
  partial_invoice_id       String?                 @unique
  pipeline_completed_count Int                     @default(0)
  pipeline_started_at      DateTime?
  student_count            Int                     // ✅ This is the correct field name
  cards                    Card[]
  finalInvoice             Invoice?                @relation("FinalInvoiceForOrder", fields: [final_invoice_id], references: [id])
  partialInvoice           Invoice?                @relation("PartialInvoiceForOrder", fields: [partial_invoice_id], references: [id])
  school                   School                  @relation(fields: [school_id], references: [id], onDelete: Cascade)
  subscription             Subscription?           @relation(fields: [subscription_id], references: [id])
  vendor                   VendorProfile?          @relation(fields: [vendor_id], references: [id])
  items                    CardOrderItem[]
  dashboardNotifications   DashboardNotification[]
  invoices                 Invoice[]
  pipeline                 OrderPipeline?
  shipment                 OrderShipment?
  statusLogs               OrderStatusLog[]
  payments                 Payment[]
  qrAssets                 QrAsset[]
  tokens                   Token[]
  tokenBatches             TokenBatch[]

  @@index([school_id])
  @@index([status])
  @@index([payment_status])
  @@index([created_at])
}

model CardOrderItem {
  id              String          @id @default(uuid())
  order_id        String
  student_id      String?
  token_id        String?         @unique
  student_name    String
  class           String?
  section         String?
  roll_number     String?
  photo_url       String?
  status          OrderItemStatus @default(PENDING)
  card_design_url String?
  card_printed    Boolean         @default(false)
  has_issue       Boolean         @default(false)
  issue_note      String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  pipeline_status PipelineStatus  @default(PENDING)
  order           CardOrder       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  student         Student?        @relation(fields: [student_id], references: [id])
  token           Token?

  @@index([order_id])
  @@index([student_id])
}

model OrderStatusLog {
  id          String       @id @default(uuid())
  order_id    String
  from_status OrderStatus?
  to_status   OrderStatus
  changed_by  String
  note        String?
  metadata    Json?
  created_at  DateTime     @default(now())
  actor_type  ActorType    @default(SYSTEM)
  order       CardOrder    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id, created_at])
}

model OrderShipment {
  id                     String            @id @default(uuid())
  order_id               String            @unique
  shiprocket_order_id    String?
  shiprocket_shipment_id String?
  awb_code               String?           @unique
  courier_name           String?
  courier_id             Int?
  tracking_url           String?
  label_url              String?
  manifest_url           String?
  pickup_vendor_id       String?
  pickup_name            String?
  pickup_contact         String?
  pickup_address         String?
  pickup_city            String?
  pickup_state           String?
  pickup_pincode         String?
  delivery_name          String?
  delivery_phone         String?
  delivery_address       String?
  delivery_city          String?
  delivery_state         String?
  delivery_pincode       String?
  status                 ShipmentStatus    @default(PENDING)
  shiprocket_status      ShiprocketStatus?
  created_by             String?
  tracking_shared_at     DateTime?
  tracking_shared_by     String?
  pickup_scheduled_at    DateTime?
  picked_up_at           DateTime?
  estimated_delivery_at  DateTime?
  delivered_at           DateTime?
  delivery_confirmed_by  String?
  notes                  String?
  created_at             DateTime          @default(now())
  updated_at             DateTime          @updatedAt
  order                  CardOrder         @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([awb_code])
}

model VendorProfile {
  id                  String       @id @default(uuid())
  name                String
  contact_name        String?
  phone               String?
  email               String?
  status              VendorStatus @default(ACTIVE)
  address             String?
  city                String?
  state               String?
  pincode             String?
  gstin               String?
  speciality          String?
  avg_turnaround_days Int?
  notes               String?
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt
  orders              CardOrder[]

  @@index([status])
}

model Card {
  id           String        @id @default(uuid())
  school_id    String
  student_id   String?
  token_id     String?
  order_id     String?
  card_number  String        @unique
  file_url     String?
  print_status PrintStatus   @default(PENDING)
  printed_at   DateTime?
  created_at   DateTime      @default(now())
  order        CardOrder?    @relation(fields: [order_id], references: [id])
  school       School        @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student      Student?      @relation(fields: [student_id], references: [id], onDelete: Cascade)
  token        Token?        @relation(fields: [token_id], references: [id])
  renewals     CardRenewal[]

  @@index([school_id])
  @@index([token_id])
  @@index([order_id])
  @@index([card_number])
}

model CardRenewal {
  id           String       @id @default(uuid())
  card_id      String
  student_id   String
  school_id    String
  renewed_by   String?
  renewer_type ActorType    @default(PARENT_USER)
  old_expiry   DateTime
  new_expiry   DateTime
  amount_paid  Int
  tax_amount   Int          @default(0)
  payment_id   String?
  school_type  SchoolType?
  pricing_tier PricingTier?
  created_at   DateTime     @default(now())
  card         Card         @relation(fields: [card_id], references: [id], onDelete: Cascade)
  payment      Payment?     @relation("RenewalPayment", fields: [payment_id], references: [id])
  school       School       @relation(fields: [school_id], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([card_id])
  @@index([student_id])
}

model Subscription {
  id                   String             @id @default(uuid())
  school_id            String
  plan                 PlanType           @default(GOVT_STANDARD)
  status               SubscriptionStatus @default(TRIALING)
  pricing_tier         PricingTier        @default(PRIVATE_STANDARD)
  student_count        Int                @default(0)
  unit_price           Int                @default(19900)
  grand_total          Int                @default(0)
  fully_paid_at        DateTime?
  current_period_start DateTime
  current_period_end   DateTime
  trial_ends_at        DateTime?
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt
  cardOrders           CardOrder[]
  invoices             Invoice[]
  school               School             @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([school_id])
  @@index([status])
}

model Invoice {
  id                   String              @id @default(uuid())
  school_id            String
  invoice_number       String              @unique
  student_count        Int
  unit_price           Int
  amount               Int
  tax_amount           Int
  total_amount         Int
  status               InvoiceStatus       @default(ISSUED)  // ✅ No DRAFT status
  issued_at            DateTime            @default(now())
  due_at               DateTime?
  paid_at              DateTime?
  pdf_url              String?
  order_id             String?
  subscription_id      String?
  category             InvoiceCategory
  order_invoice_type   OrderInvoiceType?
  pdf_generated_at     DateTime?
  renewal_invoice_type RenewalInvoiceType?
  finalOrder           CardOrder?          @relation("FinalInvoiceForOrder")
  partialOrder         CardOrder?          @relation("PartialInvoiceForOrder")
  order                CardOrder?          @relation(fields: [order_id], references: [id], onDelete: Cascade)
  school               School              @relation(fields: [school_id], references: [id], onDelete: Cascade)
  subscription         Subscription?       @relation(fields: [subscription_id], references: [id])
  payments             Payment[]

  @@index([order_id])
  @@index([category, order_invoice_type])
  @@index([status])
  @@index([invoice_number])
}

model Payment {
  id              String        @id @default(uuid())
  school_id       String
  order_id        String
  invoice_id      String?
  amount          Int
  payment_ref     String?       @unique  // ✅ ADDED for duplicate detection
  status          PaymentStatus @default(PENDING)  // ✅ FIXED: PENDING default, not SUCCESS
  payment_mode    PaymentMode   @default(BANK_TRANSFER)
  is_advance      Boolean       @default(true)
  metadata        Json?
  created_at      DateTime      @default(now())
  subscription_id String?
  renewals        CardRenewal[] @relation("RenewalPayment")
  invoice         Invoice?      @relation(fields: [invoice_id], references: [id])
  order           CardOrder     @relation(fields: [order_id], references: [id], onDelete: Cascade)
  school          School        @relation(fields: [school_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([invoice_id])
  @@index([created_at])
  @@index([payment_ref])  // ✅ ADDED index for payment_ref
}

model DashboardNotification {
  id             String                    @id @default(uuid())
  user_id        String
  user_type      DashboardUserType
  type           DashboardNotificationType
  title          String
  body           String
  metadata       Json?
  read           Boolean                   @default(false)
  read_at        DateTime?
  created_at     DateTime                  @default(now())
  school_id      String?
  order_id       String?
  school_user_id String?
  super_admin_id String?
